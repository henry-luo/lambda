// Phase 1 smoke test (multi-page): verifies pdf_to_svg works for each page
// of a 3-page PDF generated by libharu in the gtest fixture.
//
// Procedural form because the pdf API is `pn` (drives the content-stream
// interpreter via var/while).

import pdf: lambda.package.pdf.pdf

pn main() {
    let doc^err = input("test/pdf/data/basic/advanced_test.pdf", 'pdf')
    let n = pdf.pdf_page_count(doc)
    var pages = []
    var i = 0
    while (i < n) {
        pages = pages ++ [format(pdf.pdf_to_svg(doc, i, null), 'xml')]
        i = i + 1
    }
    print({
        page_count: n,
        pages: pages
    })
}
