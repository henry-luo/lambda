// Typed-array serialization through JSON/YAML/TOML formatters.
// Closes the pre-existing gap: ArrayNum (1-D and N-D) used to format as "null".
// Now they emit proper nested array literals via stride-walking inline helpers.

// ============================================================
// JSON — 1-D
// ============================================================
'=== json 1-D int ==='
format([1, 2, 3], "json")

'=== json 1-D float ==='
format([1.5, 2.5, 3.5], "json")

'=== json empty ==='
format([], "json")

// ============================================================
// JSON — N-D
// ============================================================
'=== json 2-D ==='
format([[1, 2, 3], [4, 5, 6]], "json")

'=== json 3-D ==='
format([[[1, 2], [3, 4]], [[5, 6], [7, 8]]], "json")

// ============================================================
// JSON — mixed in object
// ============================================================
'=== json object with typed array ==='
format({matrix: [[1, 2], [3, 4]], vector: [10, 20, 30]}, "json")

// ============================================================
// YAML — 1-D
// ============================================================
'=== yaml 1-D ==='
format([1, 2, 3], "yaml")

// ============================================================
// YAML — 2-D
// ============================================================
'=== yaml 2-D ==='
format([[1, 2], [3, 4]], "yaml")

// ============================================================
// TOML — 1-D and N-D
// ============================================================
'=== toml 1-D ==='
format({v: [1, 2, 3]}, "toml")

'=== toml 2-D ==='
format({m: [[1, 2], [3, 4]]}, "toml")

// ============================================================
// COMPACT TYPES — JSON
// ============================================================
'=== json compact i8 ==='
format([1i8, 2i8, 3i8], "json")

'=== json compact f32 ==='
format([1.5f32, 2.5f32], "json")

// ============================================================
// BOOL — JSON
// ============================================================
'=== json bool array ==='
format([true, false, true], "json")

// ============================================================
// FLOATS — N-D
// ============================================================
'=== json 2-D floats ==='
format([[1.5, 2.5], [3.5, 4.5]], "json")
