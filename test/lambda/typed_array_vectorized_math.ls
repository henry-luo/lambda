// Vectorized scalar math sysfuncs over ArrayNum
// Phase 2a §3 of Lambda_Typed_Array2.md
// Covers: math.sqrt/log/exp/sin/cos/tan/asin/acos/atan/sinh/cosh/tanh/log2/log10/log1p/exp2/expm1/cbrt
//         abs, round, floor, ceil, trunc, sign, neg (unary -), and the new clip()

// ============================================================
// SQUARE ROOT
// ============================================================
'=== math.sqrt ==='
math.sqrt([1, 4, 9, 16, 25])
math.sqrt([0.25, 1.0, 4.0])
math.sqrt([])
math.sqrt(16)

// ============================================================
// LOGARITHMS
// ============================================================
'=== math.log natural ==='
math.log([1, 2.718281828, 7.389056099])
math.log(1)

'=== math.log10 ==='
math.log10([1, 10, 100, 1000])

'=== math.log2 ==='
math.log2([1, 2, 4, 8, 16])

// ============================================================
// EXPONENTIALS
// ============================================================
'=== math.exp ==='
math.exp([0, 1, 2])

'=== math.exp2 ==='
math.exp2([0, 1, 2, 3])

// ============================================================
// TRIGONOMETRY
// ============================================================
'=== math.sin ==='
math.sin([0, 1.5707963268, 3.1415926536])

'=== math.cos ==='
math.cos([0, 1.5707963268, 3.1415926536])

'=== math.tan ==='
math.tan([0, 0.7853981634])

// ============================================================
// INVERSE TRIG
// ============================================================
'=== math.asin ==='
math.asin([0, 0.5, 1])

'=== math.acos ==='
math.acos([1, 0.5, 0])

'=== math.atan ==='
math.atan([0, 1])

// ============================================================
// HYPERBOLIC
// ============================================================
'=== math.sinh ==='
math.sinh([0, 1])

'=== math.cosh ==='
math.cosh([0, 1])

'=== math.tanh ==='
math.tanh([0, 1])

// ============================================================
// TYPE-PRESERVING (currently float-promoting per existing impl)
// ============================================================
'=== abs vectorized ==='
abs([-1, -2, 3, -4])
abs([-1.5, 2.5, -3.5])
abs(-5)
abs([])

'=== round vectorized ==='
round([1.2, 1.5, 1.8, -1.5])
round([1, 2, 3])

'=== floor vectorized ==='
floor([1.2, 1.9, -0.5])

'=== ceil vectorized ==='
ceil([1.2, 1.9, -0.5])

'=== trunc vectorized ==='
trunc([1.7, -1.7, 2.0])

'=== sign vectorized ==='
sign([-3, 0, 5, -0.5, 2.5])
sign(-7)

// ============================================================
// UNARY NEG (new array support)
// ============================================================
'=== neg vectorized ==='
let arr_i = [1, 2, 3]
-arr_i
let arr_f = [1.5, -2.5, 3.5]
-arr_f
-[]
-(1 to 3)

// ============================================================
// NEW: CLIP
// ============================================================
'=== clip scalar ==='
clip(5, 0, 10)
clip(-3, 0, 10)
clip(15, 0, 10)
clip(7.5, 0.0, 10.0)
clip(5, 5, 5)

'=== clip vector ==='
clip([1, 5, 10, 15, 20], 5, 15)
clip([-1.5, 0.5, 2.5, 5.5], 0.0, 2.0)
clip([], 0, 10)
clip(1 to 10, 3, 7)

// ============================================================
// COMPOSITION / PIPELINES
// ============================================================
'=== composition ==='
math.sqrt(clip([-4, 4, 16, 100], 0, 25))
clip(math.sqrt([1, 4, 9, 16, 25]), 2, 4)
sum(math.exp([0, 1, 2]))
