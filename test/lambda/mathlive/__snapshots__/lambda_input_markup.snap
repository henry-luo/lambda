%"><span class="lm_cmr">2</span></span></span></span></span></span></span></span></span></span></span></span></span><span class="lm_mathit">dx</span><span style="display:inline-block;width:0.28em"></span><span class="lm_cmr">=</span><span style="display:inline-block;width:0.28em"></span><span style="display:inline-block;height:1.21em"><span class="lm_sqrt-sign" style="top:-0.01em"><span class="lm_delim-size1">√</span></span><span class="lm_vlist-t"><span class="lm_vlist-r"><span class="lm_vlist" style="height:0.87em"><span style="top:-3em"><span class="lm_pstrut" style="height:3em"></span><span style="height:0.44em;display:inline-block"><span class="lcGreek lm_mathit" style="margin-right:0.04em">π</span></span></span><span style="top:-3.78em"><span class="lm_pstrut" style="height:3em"></span><span class="lm_sqrt-line" style="height:0.04em;display:inline-block"></span></span></span></span></span></span></span></span></span><span class="lm_vlist-s">​</span></span><span class="lm_vlist-r"><span class="lm_vlist" style="height:0.93em"></span></span></span></span><span class="lm_arraycolsep" style="width:0.5em"></span></span></span></span>",
