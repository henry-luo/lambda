// Axis-aware reductions for typed N-D arrays
// Phase 2 §1 — sum/avg/prod/mean(arr, axis) collapse; cumsum/cumprod(arr, axis) run.
// 1-arg whole-array forms unchanged.

// ============================================================
// SUM
// ============================================================
'=== sum ==='
let m = [[1, 2, 3], [4, 5, 6]]
sum(m)                          // 21 (whole array, unchanged)
sum(m, 0)                       // [5, 7, 9]  column sums
sum(m, 1)                       // [6, 15]    row sums
sum(m, -1)                      // [6, 15]    negative axis

'=== sum 1-D (scalar) ==='
sum([1, 2, 3, 4], 0)            // 10

// ============================================================
// AVG / MEAN
// ============================================================
'=== avg ==='
avg(m, 0)                       // [2.5, 3.5, 4.5]
avg(m, 1)                       // [2, 5]
math.mean(m, 0)                 // same as avg: [2.5, 3.5, 4.5]

// ============================================================
// PROD
// ============================================================
'=== prod ==='
math.prod(m, 0)                 // [4, 10, 18]
math.prod(m, 1)                 // [6, 120]

// ============================================================
// MIN / MAX — positional axis AND axis: named param
// (pairwise min(a,b) scalar form is preserved — array-first is the axis form)
// ============================================================
'=== min/max axis ==='
let mm = [[1, 5, 3], [4, 2, 6]]
min(mm)                         // 1   (whole, 1-arg)
max(mm)                         // 6
min(mm, 0)                      // [1, 2, 3]  column mins
min(mm, 1)                      // [1, 2]     row mins
max(mm, 0)                      // [4, 5, 6]
max(mm, 1)                      // [5, 6]
min(mm, axis: 0)                // [1, 2, 3]  (named param form)
max(mm, axis: 1)                // [5, 6]
min(3, 7)                       // 3  (pairwise scalar — still works)
max(3, 7)                       // 7

// ============================================================
// 3-D REDUCTIONS
// ============================================================
'=== 3-D ==='
let t = reshape([1, 2, 3, 4, 5, 6, 7, 8], [2, 2, 2])
sum(t, 0)                       // [[6, 8], [10, 12]]
sum(t, 1)                       // [[4, 6], [12, 14]]
sum(t, 2)                       // [[3, 7], [11, 15]]
shape(sum(t, 0))                // [2, 2]

// ============================================================
// CUMSUM (running, same shape)
// ============================================================
'=== cumsum ==='
math.cumsum([1, 2, 3, 4])              // [1, 3, 6, 10] (1-arg)
math.cumsum(m, 0)                      // [[1, 2, 3], [5, 7, 9]]
math.cumsum(m, 1)                      // [[1, 3, 6], [4, 9, 15]]
shape(math.cumsum(m, 1))               // [2, 3] — same shape

// ============================================================
// CUMPROD
// ============================================================
'=== cumprod ==='
math.cumprod(m, 0)                     // [[1, 2, 3], [4, 10, 18]]
math.cumprod(m, 1)                     // [[1, 2, 6], [4, 20, 120]]

// ============================================================
// NON-CONTIGUOUS (transpose) — strided read
// ============================================================
'=== reductions on transpose ==='
sum(transpose(m), 0)                   // transpose is (3,2): col sums [6, 15]
sum(transpose(m), 1)                   // row sums [5, 7, 9]
math.cumsum(transpose(m), 1)           // running along rows of the transpose

// ============================================================
// FLOAT
// ============================================================
'=== float ==='
let fm = reshape([1.5, 2.5, 3.5, 4.5], [2, 2])
sum(fm, 0)                             // [5, 7]
avg(fm, 1)                             // [2, 4]

// ============================================================
// COMPOSITION
// ============================================================
'=== composition ==='
sum(sum(t, 0))                         // sum the 2-D result: 36
sum(sum(m, 0), 0)                      // sum([5,7,9]) = 21 (== whole sum)

// ============================================================
// ERRORS
// ============================================================
'=== errors ==='
sum(m, 5)                              // axis out of range
sum([1, 2, 3])                         // 6 (1-arg still works)
