// Extended precision decimal tests using the unified 'n' suffix.
// Fractional literals remain decimal; integer-like literals are integer.

"===== BASIC EXTENDED DECIMAL LITERALS ====="
3.14159n
2.71828n
0.0n
-1.5n
123456789.987654321n

"===== HIGH PRECISION DECIMAL LITERALS ====="
// More than 38 digits - should preserve full precision
3.14159265358979323846264338327950288419n
2.71828182845904523536028747135266249775n

"===== EXTENDED DECIMAL ADDITION ====="
3.14159n + 2.71828n
3.14159265358979323846264338327950288419n + 2.71828182845904523536028747135266249775n
0.0n + (-1.5n)
123456789.987654321n + 3.14159n

"===== MIXED DECIMAL PRECISION ====="
3.14159n + 2.71828n
3.14159n + 2.71828n
5n + 10n
10n + 5n

"===== EXTENDED DECIMAL SUBTRACTION ====="
3.14159n - 2.71828n
3.14159265358979323846264338327950288419n - 2.71828182845904523536028747135266249775n
2.71828n - 3.14159n
0.0n - (-1.5n)

"===== EXTENDED DECIMAL MULTIPLICATION ====="
3.14159n * 2.71828n
3.14159265358979323846264338327950288419n * 2.71828182845904523536028747135266249775n
(-1.5n) * (-1.5n)
0.0n * 123456789.987654321n

"===== EXTENDED DECIMAL DIVISION ====="
3.14159n / 2.71828n
1n / 3n
10n / 3n
3.14159265358979323846264338327950288419n / 2.71828182845904523536028747135266249775n
(-1.5n) / (-1.5n)

"===== EXTENDED DECIMAL MODULO ====="
7.5n % 2.3n
3.14159n % 1.0n
10n % 3n

"===== EXTENDED DECIMAL POWER ====="
2.71828n ** 2
3.14159n ** 0.5
2n ** 10

"===== MIXED WITH INTEGER ====="
3.14159n + 5
10 + 2.71828n
3.14159n * 2
3 * (-1.5n)
3.14159n / 2
10 / 2.71828n

"===== MIXED WITH FLOAT ====="
3.14159n + 1.5
2.5 + 2.71828n
3.14159n * 0.5
2.0 * 2.71828n
3.14159n / 2.0
6.28318 / 3.14159n

"===== VARIABLES WITH EXTENDED DECIMAL ====="
let pi_big = 3.14159265358979323846264338327950288419n
let e_big = 2.71828182845904523536028747135266249775n
pi_big
e_big
pi_big + e_big
pi_big * e_big
pi_big / e_big

"===== ARRAYS WITH EXTENDED DECIMAL ====="
[1.5n, 2.75n, 3.14159265358979323846264338327950288419n]

"===== COMPARISON: DECIMAL TIERS ====="
// These should behave the same way mathematically
3.14159n + 2.71828n
3.141590000000000000000000000000000000001n + 2.718279999999999999999999999999999999999n

"===== END OF EXTENDED DECIMAL TESTS ====="
