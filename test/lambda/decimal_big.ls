// Extended precision decimal tests using the unified 'n' suffix.
// Fractional literals remain decimal; integer-like literals are integer.

"===== BASIC EXTENDED DECIMAL LITERALS ====="
3.14159m
2.71828m
0.0m
-1.5m
123456789.987654321m

"===== HIGH PRECISION DECIMAL LITERALS ====="
// More than 38 digits - should preserve full precision
3.14159265358979323846264338327950288419m
2.71828182845904523536028747135266249775m

"===== EXTENDED DECIMAL ADDITION ====="
3.14159m + 2.71828m
3.14159265358979323846264338327950288419m + 2.71828182845904523536028747135266249775m
0.0m + (-1.5m)
123456789.987654321m + 3.14159m

"===== MIXED DECIMAL PRECISION ====="
3.14159m + 2.71828m
3.14159m + 2.71828m
5n + 10n
10n + 5n

"===== EXTENDED DECIMAL SUBTRACTION ====="
3.14159m - 2.71828m
3.14159265358979323846264338327950288419m - 2.71828182845904523536028747135266249775m
2.71828m - 3.14159m
0.0m - (-1.5m)

"===== EXTENDED DECIMAL MULTIPLICATION ====="
3.14159m * 2.71828m
3.14159265358979323846264338327950288419m * 2.71828182845904523536028747135266249775m
(-1.5m) * (-1.5m)
0.0m * 123456789.987654321m

"===== EXTENDED DECIMAL DIVISION ====="
3.14159m / 2.71828m
1n / 3n
10n / 3n
3.14159265358979323846264338327950288419m / 2.71828182845904523536028747135266249775m
(-1.5m) / (-1.5m)

"===== EXTENDED DECIMAL MODULO ====="
7.5m % 2.3m
3.14159m % 1.0m
10n % 3n

"===== EXTENDED DECIMAL POWER ====="
2.71828m ** 2
3.14159m ** 0.5
2n ** 10

"===== MIXED WITH INTEGER ====="
3.14159m + 5
10 + 2.71828m
3.14159m * 2
3 * (-1.5m)
3.14159m / 2
10 / 2.71828m

"===== MIXED WITH FLOAT ====="
3.14159m + 1.5
2.5 + 2.71828m
3.14159m * 0.5
2.0 * 2.71828m
3.14159m / 2.0
6.28318 / 3.14159m

"===== VARIABLES WITH EXTENDED DECIMAL ====="
let pi_big = 3.14159265358979323846264338327950288419m
let e_big = 2.71828182845904523536028747135266249775m
pi_big
e_big
pi_big + e_big
pi_big * e_big
pi_big / e_big

"===== ARRAYS WITH EXTENDED DECIMAL ====="
[1.5m, 2.75m, 3.14159265358979323846264338327950288419m]

"===== COMPARISON: DECIMAL TIERS ====="
// These should behave the same way mathematically
3.14159m + 2.71828m
3.141590000000000000000000000000000000001m + 2.718279999999999999999999999999999999999m

"===== END OF EXTENDED DECIMAL TESTS ====="
