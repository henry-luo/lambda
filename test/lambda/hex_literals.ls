// Test hexadecimal integer literals, including fixed-width integer suffixes.

"=== plain hex ==="
0x0
0xF
0x80
0xFF
0xD008
0X5A827999
0xFFFFFFFF
type(0xFFFFFFFF)

"=== sized hex ==="
0xFFi8
type(0xFFi8)
0x80u8
type(0x80u8)
0xFFFFi16
type(0xFFFFi16)
0xFFFFFFFFu32
type(0xFFFFFFFFu32)
0xFFFFFFFFFFFFFFFFu64
type(0xFFFFFFFFFFFFFFFFu64)

"=== expressions ==="
band(0xFFFFFFFFu32, 0xFFu32)
bor(0xD000, 0x008)
0x7Fi8 + 0x01i8
type(0x7Fi8 + 0x01i8)
