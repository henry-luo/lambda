{
  "schema_version": 1,
  "description": "Self-recursive tail call is turned into a counter-guarded loop: the function contains no call back into itself, and carries the TCO counter and dummy registers. The 1000000 literal is the documented TCO iteration cap (JO10 in vibe/Lambda_Design_Stack_Frame_JS.md), a semantic constant rather than a baked address, so pinning it is deliberate.",
  "checks": [
    {
      "in_func": "_factorial_#",
      "forbid": [
        "call\t_factorial_"
      ],
      "expect": [
        "tco_count_",
        "tco_dummy_"
      ],
      "count": {
        ", 1000000": 1
      }
    }
  ]
}
