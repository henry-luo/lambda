{
  "name": "RTE dragging selected text moves it to the drop caret",
  "html": "test/ui/rte_prototype.ls",
  "timeout": 5000,
  "events": [
    {"type": "wait", "ms": 500},
    {"type": "mouse_drag", "target": {"text": "simple markdown"}, "to_target": {"text": "testing basic"}, "button": 0},
    {"type": "wait", "ms": 100},
    {"type": "assert_selection", "is_collapsed": false, "check_dom": true},
    {"type": "mouse_down", "target": {"text": "simple markdown"}, "button": 0},
    {"type": "wait", "ms": 60},
    {"type": "mouse_move", "target": {"text": "That's all"}},
    {"type": "wait", "ms": 60},
    {"type": "mouse_up", "target": {"text": "That's all"}, "button": 0},
    {"type": "wait", "ms": 200},
    {"type": "assert_selection", "is_collapsed": true, "check_dom": true},
    {"type": "assert_text", "target": {"selector": "#doc"}, "contains": "This is a sir testing basic functionality."},
    {"type": "assert_text", "target": {"selector": "#doc"}, "contains": "mple markdown document foThat's all"}
  ]
}