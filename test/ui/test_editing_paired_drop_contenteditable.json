{
  "name": "Editing paired drop - contenteditable applies default drop transactions",
  "html": "test/ui/editing/contenteditable.html",
  "viewport": {"width": 640, "height": 360},
  "events": [
    {"type": "log", "message": "=== editing_paired_drop_contenteditable ==="},
    {"type": "wait", "ms": 150},
    {"type": "editing_text_drag_drop",
     "target": {"selector": "#surface", "start": 0, "end": 2},
     "to_target": {"selector": "#surface", "start": 4, "end": 4},
     "text": "se",
     "html": "<b>se</b>",
     "move": true},
    {"type": "wait", "ms": 80},
    {"type": "assert_text", "target": {"selector": "#surface"}, "equals": "edse"},
    {"type": "assert_text", "target": {"selector": "#before-log"}, "contains": "before:insertFromDrop|se|1|2-2|dt:text/plain,text/html:plain=se:html=<b>se</b>"},
    {"type": "assert_text", "target": {"selector": "#input-log"}, "contains": "input:insertFromDrop|se|edse|ranges:1|2-2|dt:text/plain,text/html:plain=se:html=<b>se</b>"},
    {"type": "assert_editing_event", "event": "editing.beforeinput", "inputType": "deleteByDrag", "surface": "contenteditable", "min": 1},
    {"type": "assert_editing_event", "event": "editing.beforeinput", "inputType": "insertFromDrop", "surface": "contenteditable", "min": 1},
    {"type": "assert_editing_event", "event": "editing.transaction", "inputType": "deleteByDrag", "surface": "contenteditable", "operation": "default", "min": 2},
    {"type": "assert_editing_event", "event": "editing.transaction", "inputType": "insertFromDrop", "surface": "contenteditable", "operation": "default", "min": 2},
    {"type": "assert_event_log", "contains": "\"owned_by\":\"consumer\"", "min": 1}
  ]
}
