{
  "name": "Editing paired fixture - contenteditable typing and cancellation",
  "html": "test/ui/editing/contenteditable.html",
  "viewport": {"width": 640, "height": 360},
  "events": [
    {"type": "log", "message": "=== editing_paired_contenteditable ==="},
    {"type": "wait", "ms": 150},
    {"type": "click", "target": {"selector": "#surface"}},
    {"type": "wait", "ms": 60},
    {"type": "key_combo", "key": "a", "mods_str": "super"},
    {"type": "wait", "ms": 60},
    {"type": "type", "target": {"selector": "#surface"}, "text": "X"},
    {"type": "wait", "ms": 80},
    {"type": "assert_text", "target": {"selector": "#surface"}, "equals": "seed"},
    {"type": "assert_text", "target": {"selector": "#blocked-log"}, "contains": "blocked:insertText|X|"},
    {"type": "assert_text", "target": {"selector": "#input-log"}, "equals": "input:none"},
    {"type": "type", "target": {"selector": "#surface"}, "text": "Y"},
    {"type": "wait", "ms": 80},
    {"type": "assert_text", "target": {"selector": "#surface"}, "equals": "seedY"},
    {"type": "assert_text", "target": {"selector": "#before-log"}, "contains": "before:insertText|Y|"},
    {"type": "assert_text", "target": {"selector": "#input-log"}, "contains": "input:insertText|Y|seedY"}
  ]
}
