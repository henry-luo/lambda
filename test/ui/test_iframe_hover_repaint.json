    {"type": "assert_pixel", "target": {"selector": "#frame", "offset_x": 20, "offset_y": 40}, "force_render": false, "min_r": 55, "max_r": 85, "min_g": 145, "max_g": 175, "min_b": 80, "max_b": 115}
