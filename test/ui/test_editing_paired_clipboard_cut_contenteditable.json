{
  "name": "Editing paired clipboard cut - contenteditable deleteByCut intent",
  "html": "test/ui/editing/contenteditable.html",
  "viewport": {"width": 640, "height": 360},
  "events": [
    {"type": "log", "message": "=== editing_paired_clipboard_cut_contenteditable ==="},
    {"type": "wait", "ms": 150},
    {"type": "set_editing_selection", "target": {"selector": "#surface"}, "start": 0, "end": 2},
    {"type": "key_combo", "key": "x", "mods_str": "super"},
    {"type": "wait", "ms": 80},
    {"type": "assert_clipboard", "equals": "se"},
    {"type": "assert_text", "target": {"selector": "#before-log"}, "contains": "before:deleteByCut||1|0-2"},
    {"type": "assert_editing_value", "target": {"selector": "#surface"}, "equals": "ed"},
    {"type": "assert_editing_event", "event": "editing.beforeinput", "inputType": "deleteByCut", "surface": "contenteditable", "prevented": false, "min": 1},
    {"type": "assert_editing_event", "event": "editing.transaction", "inputType": "deleteByCut", "surface": "contenteditable", "min": 2}
  ]
}
