{
  "name": "Editing autoscroll reaches text controls and nearest scroll container",
  "html": "test/ui/test_editing_autoscroll_controls.html",
  "viewport": {"width": 640, "height": 420},
  "events": [
    {"type": "log", "message": "=== editing_autoscroll_controls ==="},

    {"type": "log", "message": "Rich drag autoscroll uses the nearest scroll container, not the document viewport"},
    {"type": "mouse_move", "target": {"selector": "#scrollHost", "offset_x": 216, "offset_y": 20}},
    {"type": "assert_state_store", "target": {"selector": "#scrollHost"}, "view_state": true, "kind": "scroll",
     "scrollbar_v_hovered": true},
    {"type": "mouse_down", "target": {"text": "Rich start"}, "button": 0},
    {"type": "mouse_move", "target": {"selector": "#scrollHost", "offset_x": 100, "offset_y": 140}},
    {"type": "assert_selection", "is_collapsed": false},
    {"type": "advance_time", "ms": 128, "steps": 4},
    {"type": "mouse_up", "target": {"selector": "#scrollHost", "offset_x": 100, "offset_y": 140}, "button": 0},
    {"type": "assert_state_store", "target": {"selector": "#scrollHost"}, "view_scroll_y": 120, "tolerance": 90},
    {"type": "assert_state_store", "doc_scroll_y": 0, "tolerance": 2},

    {"type": "log", "message": "Input drag autoscroll extends selection while pointer is held near the right edge"},
    {"type": "mouse_down", "target": {"selector": "#longInput", "offset_x": 4, "offset_y": 11}, "button": 0},
    {"type": "mouse_move", "target": {"selector": "#longInput", "offset_x": 148, "offset_y": 11}},
    {"type": "advance_time", "ms": 128, "steps": 4},
    {"type": "mouse_up", "target": {"selector": "#longInput", "offset_x": 148, "offset_y": 11}, "button": 0},
    {"type": "assert_form_selection", "target": {"selector": "#longInput"}, "start": 0, "end": 41},

    {"type": "log", "message": "Textarea drag autoscroll extends selection downward through internal scroll"},
    {"type": "mouse_down", "target": {"selector": "#longArea", "offset_x": 4, "offset_y": 8}, "button": 0},
    {"type": "mouse_move", "target": {"selector": "#longArea", "offset_x": 170, "offset_y": 54}},
    {"type": "advance_time", "ms": 128, "steps": 4},
    {"type": "mouse_up", "target": {"selector": "#longArea", "offset_x": 170, "offset_y": 54}, "button": 0},
    {"type": "assert_form_selection", "target": {"selector": "#longArea"}, "start": 0, "end": 35}
  ]
}
