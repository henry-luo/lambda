{
  "name": "Form textarea - keyboard Cut uses unified editing transaction",
  "html": "test/ui/test_form_input.html",
  "viewport": {"width": 600, "height": 600},
  "events": [
    {"type": "log", "message": "=== form_textarea_cut_keyboard ==="},

    {"type": "click", "target": {"selector": "#bio"}},
    {"type": "wait", "ms": 80},
    {"type": "paste_text", "target": {"selector": "#bio"}, "text": "ab\ncd"},
    {"type": "assert_value", "target": {"selector": "#bio"}, "equals": "ab\ncd"},

    {"type": "key_press", "key": "Home"},
    {"type": "wait", "ms": 60},
    {"type": "key_press", "key": "Right", "mods_str": "shift"},
    {"type": "assert_selection", "is_collapsed": false},

    {"type": "key_combo", "key": "x", "mods_str": "super"},
    {"type": "assert_clipboard", "equals": "c"},
    {"type": "assert_value", "target": {"selector": "#bio"}, "equals": "ab\nd"},
    {"type": "assert_caret", "char_offset": 3},
    {"type": "assert_state_dump", "reference": "test/ui/state/test_form_textarea_cut_keyboard_final.mark"}
  ]
}
