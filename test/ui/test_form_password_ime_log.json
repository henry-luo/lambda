{
  "name": "Form password - IME event log redacts composition lengths",
  "html": "test/ui/test_form_input.html",
  "viewport": {"width": 600, "height": 600},
  "events": [
    {"type": "log", "message": "=== form_password_ime_log ==="},
    {"type": "click", "target": {"selector": "#pwd"}},
    {"type": "wait", "ms": 80},
    {"type": "ime_compose", "phase": "begin"},
    {"type": "wait", "ms": 40},
    {"type": "ime_compose", "phase": "update", "preedit": "に", "caret": 1},
    {"type": "wait", "ms": 40},
    {"type": "ime_compose", "phase": "commit", "commit": "日本"},
    {"type": "assert_value", "target": {"selector": "#pwd"}, "equals": "日本"},
    {"type": "assert_event_log", "contains": "\"redacted\":true", "min": 1},
    {"type": "assert_event_log", "contains": "\"commit_len\":0", "min": 1},
    {"type": "assert_state_dump", "reference": "test/ui/state/test_form_password_ime_log_final.mark"}
  ]
}
