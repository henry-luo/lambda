{
  "name": "Editing paired history - textarea undo and redo",
  "html": "test/ui/editing/textarea.html",
  "viewport": {"width": 640, "height": 380},
  "events": [
    {"type": "log", "message": "=== editing_paired_history_textarea ==="},
    {"type": "click", "target": {"selector": "#surface"}},
    {"type": "paste_text", "target": {"selector": "#surface"}, "text": "ab"},
    {"type": "wait", "ms": 80},
    {"type": "key_combo", "key": "z", "mods_str": "super"},
    {"type": "assert_event_log", "contains": "\"type\":\"editing.history\"", "min": 1},
    {"type": "assert_event_log", "contains": "\"input_type\":\"historyUndo\"", "min": 1}
  ]
}
