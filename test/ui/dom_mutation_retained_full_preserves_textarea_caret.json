{
  "name": "DOM mutation retained full preserves textarea caret",
  "html": "test/ui/dom_mutation_retained_full_preserves_textarea_caret.html",
  "viewport": {"width": 640, "height": 320},
  "events": [
    {"type": "click", "target": {"selector": "#editor"}},
    {"type": "wait", "ms": 80},
    {"type": "set_editing_selection", "target": {"selector": "#editor"}, "start": 2},
    {"type": "assert_caret", "target": {"selector": "#editor"}, "char_offset": 2},
    {"type": "assert_state_store", "target": {"selector": "#editor"}, "view_state": true, "kind": "form", "weak_ref": true},
    {"type": "snapshot_state_store", "name": "editor-form", "target": {"selector": "#editor"}},
    {"type": "type", "target": {"selector": "#editor"}, "text": "X"},
    {"type": "assert_value", "target": {"selector": "#editor"}, "equals": "abXcd"},
    {"type": "assert_caret", "target": {"selector": "#editor"}, "char_offset": 3},
    {"type": "assert_reconcile_mode", "mode": "retained_full_layout", "reason": "stylesheet-mutation"},
    {"type": "assert_state_store_snapshot", "name": "editor-form", "target": {"selector": "#editor"}}
  ]
}
