{
  "name": "Form textarea - caret navigation uses unified editing surface",
  "html": "test/ui/test_form_input.html",
  "viewport": {"width": 600, "height": 600},
  "events": [
    {"type": "log", "message": "=== form_textarea_caret_navigation ==="},
    {"type": "wait", "ms": 200},

    {"type": "click", "target": {"selector": "#bio"}},
    {"type": "wait", "ms": 80},
    {"type": "paste_text", "target": {"selector": "#bio"}, "text": "ab\ncd"},
    {"type": "wait", "ms": 80},
    {"type": "assert_value", "target": {"selector": "#bio"}, "equals": "ab\ncd"},
    {"type": "assert_caret", "char_offset": 5},

    {"type": "key_press", "key": "Up"},
    {"type": "wait", "ms": 60},
    {"type": "assert_caret", "char_offset": 2},

    {"type": "key_press", "key": "Down"},
    {"type": "wait", "ms": 60},
    {"type": "assert_caret", "char_offset": 5},

    {"type": "key_press", "key": "Home"},
    {"type": "wait", "ms": 60},
    {"type": "assert_caret", "char_offset": 3},

    {"type": "key_press", "key": "End"},
    {"type": "wait", "ms": 60},
    {"type": "assert_caret", "char_offset": 5},

    {"type": "key_press", "key": "Left"},
    {"type": "wait", "ms": 60},
    {"type": "assert_caret", "char_offset": 4},

    {"type": "key_press", "key": "Right"},
    {"type": "wait", "ms": 60},
    {"type": "assert_caret", "char_offset": 5},
    {"type": "assert_state_dump", "reference": "test/ui/state/test_form_textarea_caret_navigation_final.mark"}
  ]
}
