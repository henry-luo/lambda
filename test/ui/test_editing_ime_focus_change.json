{
  "name": "Editing IME composition keeps original target when focus changes",
  "html": "test/ui/test_editing_ime_focus_change.html",
  "viewport": {"width": 640, "height": 520},
  "events": [
    {"type": "log", "message": "=== editing_ime_focus_change ==="},

    {"type": "click", "target": {"selector": "#field"}},
    {"type": "ime_compose", "phase": "begin"},
    {"type": "ime_compose", "phase": "update", "preedit": "pre", "caret": 3},
    {"type": "click", "target": {"selector": "#other"}},
    {"type": "assert_focus", "target": {"selector": "#other"}},
    {"type": "ime_compose", "phase": "commit", "commit": "done"},
    {"type": "assert_text", "target": {"selector": "#formLog"}, "equals": "compositionstart:|compositionupdate:pre|beforeinput:insertCompositionText:pre:1|input:insertCompositionText:pre:1|compositionend:done|beforeinput:insertFromComposition:done:0|input:insertFromComposition:done:0"},

    {"type": "assert_event_log", "contains": "\"transition\":\"focus_element\"", "min": 2},
    {"type": "assert_event_log", "contains": "\"composition\":{\"active\":true", "min": 1},
    {"type": "assert_event_log", "contains": "\"committed\":true", "min": 1}
  ]
}
