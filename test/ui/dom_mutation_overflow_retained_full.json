{
  "name": "DOM mutation record overflow uses retained full layout",
  "html": "test/ui/dom_mutation_overflow_retained_full.html",
  "viewport": {"width": 640, "height": 420},
  "events": [
    {"type": "click", "target": {"selector": "#name"}},
    {"type": "assert_focus", "target": {"selector": "#name"}},
    {"type": "assert_state_store", "target": {"selector": "#name"}, "view_state": true, "kind": "form", "weak_ref": true},
    {"type": "snapshot_state_store", "name": "focused-input", "target": {"selector": "#name"}},
    {"type": "key_press", "key": "b"},
    {"type": "assert_count", "target": {"selector": "#items .row"}, "equals": 70},
    {"type": "assert_text", "target": {"selector": "#status"}, "contains": "overflow mutation complete"},
    {"type": "assert_reconcile_mode", "mode": "retained_full_layout", "reason": "record-overflow"},
    {"type": "assert_state_store_snapshot", "name": "focused-input", "target": {"selector": "#name"}},
    {"type": "assert_focus", "target": {"selector": "#name"}},
    {"type": "assert_state_store", "target": {"selector": "#name"}, "view_state": true, "kind": "form", "weak_ref": true}
  ]
}
