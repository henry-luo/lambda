{
  "name": "editor4c-phase-c2: paste participates in undo and redo history",
  "_note": "Phase C C2 - history nuance. A multi-step paste should push one undoable history entry; toolbar undo removes it and redo restores it.",
  "html": "test/html/editor-dom.html",
  "viewport": {"width": 900, "height": 700},
  "events": [
    {"type": "wait", "ms": 250},
    {"type": "click", "target": {"selector": ".rdt-surface h1"}},
    {"type": "wait", "ms": 60},
    {"type": "key_combo", "key": "a", "mods_str": "super"},
    {"type": "wait", "ms": 80},
    {"type": "key_press", "key": "Backspace"},
    {"type": "wait", "ms": 100},
    {"type": "paste_text", "text": "one\n\ntwo"},
    {"type": "wait", "ms": 180},
    {"type": "assert_text", "target": {"selector": ".rdt-surface"}, "contains": "one"},
    {"type": "assert_text", "target": {"selector": ".rdt-surface"}, "contains": "two"},
    {"type": "click", "target": {"selector": ".rdt-toolbar button[title=\"Undo (Cmd+Z)\"]"}},
    {"type": "wait", "ms": 150},
    {"type": "assert_count", "target": {"selector": ".rdt-surface p"}, "equals": 0},
    {"type": "click", "target": {"selector": ".rdt-toolbar button[title=\"Redo (Cmd+Shift+Z)\"]"}},
    {"type": "wait", "ms": 150},
    {"type": "assert_text", "target": {"selector": ".rdt-surface"}, "contains": "one"},
    {"type": "assert_text", "target": {"selector": ".rdt-surface"}, "contains": "two"}
  ]
}
