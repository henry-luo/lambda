    {"type": "click", "target": {"selector": "button.rdt-btn[title=\"Insert mention\"]"}},
    {"type": "wait", "ms": 150},
    {"type": "assert_count", "target": {"selector": ".rdt-surface .rdt-mention"}, "equals": 1},
    {"type": "key_press", "key": "Backspace"},
    {"type": "wait", "ms": 150},
    {"type": "assert_count", "target": {"selector": ".rdt-surface .rdt-mention"}, "equals": 0}
  ]
}
