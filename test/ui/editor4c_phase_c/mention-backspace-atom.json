{
  "name": "editor4c-phase-c2: Backspace after an inserted mention deletes it as one atom",
  "_note": "Phase C C2 - inline atom deletion. Insert a mention through prompt-backed toolbar UI, then Backspace at the post-atom caret removes the whole mention node.",
  "html": "test/html/editor-dom.html",
  "viewport": {"width": 900, "height": 700},
