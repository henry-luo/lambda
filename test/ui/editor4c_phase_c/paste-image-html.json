{
  "name": "editor4c-phase-c: text/html paste inserts an image node",
  "_note": "Phase C C1 — paste image HTML path. Clear the doc and paste an img fragment through ClipboardEvent text/html; the editor parses it into an image node.",
  "html": "test/html/editor-dom.html",
  "viewport": {"width": 900, "height": 700},
  "events": [
    {"type": "wait", "ms": 250},
    {"type": "click", "target": {"selector": ".rdt-surface h1"}},
    {"type": "wait", "ms": 60},
    {"type": "key_combo", "key": "a", "mods_str": "super"},
    {"type": "wait", "ms": 80},
    {"type": "key_press", "key": "Backspace"},
    {"type": "wait", "ms": 100},
    {"type": "paste_text", "text": "", "html": "<img src=\"data:pic\" alt=\"p\">"},
    {"type": "wait", "ms": 180},
    {"type": "assert_count", "target": {"selector": ".rdt-surface img"}, "equals": 1},
    {"type": "assert_attribute", "target": {"selector": ".rdt-surface img"}, "attribute": "src", "contains": "data:pic"}
  ]
}
