{
  "name": "Form input - context menu opens on right-click and Esc closes",
  "html": "test/ui/test_form_input.html",
  "viewport": {"width": 600, "height": 600},
  "events": [
    {"type": "log", "message": "=== form_context_menu ==="},
    {"type": "wait", "ms": 200},

    {"type": "click", "target": {"selector": "#name"}},
    {"type": "wait", "ms": 80},
    {"type": "paste_text", "target": {"selector": "#name"}, "text": "ctxmenu"},
    {"type": "wait", "ms": 80},

    {"type": "log", "message": "Right-click (button=1) on input opens context menu"},
    {"type": "click", "target": {"selector": "#name"}, "button": 1},
    {"type": "wait", "ms": 100},

    {"type": "log", "message": "Esc closes the menu without modifying value"},
    {"type": "key_press", "key": "escape"},
    {"type": "wait", "ms": 80},
    {"type": "assert_value", "target": {"selector": "#name"}, "equals": "ctxmenu"}
  ]
}
