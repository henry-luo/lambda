{
  "name": "Form input - select all uses unified editing surface",
  "html": "test/ui/test_form_input.html",
  "viewport": {"width": 600, "height": 600},
  "events": [
    {"type": "log", "message": "=== form_input_select_all ==="},

    {"type": "click", "target": {"selector": "#name"}},
    {"type": "assert_focus", "target": {"selector": "#name"}},

    {"type": "type", "target": {"selector": "#name"}, "text": "abc"},
    {"type": "assert_value", "target": {"selector": "#name"}, "equals": "abc"},

    {"type": "key_combo", "key": "a", "mods_str": "super"},
    {"type": "assert_selection", "is_collapsed": false},

    {"type": "type", "target": {"selector": "#name"}, "text": "X"},
    {"type": "assert_value", "target": {"selector": "#name"}, "equals": "X"},
    {"type": "assert_state_dump", "reference": "test/ui/state/test_form_input_select_all_final.mark"}
  ]
}
