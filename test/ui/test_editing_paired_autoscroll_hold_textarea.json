{
  "name": "Editing paired autoscroll hold - textarea deterministic ticks",
  "html": "test/ui/editing/textarea.html",
  "viewport": {"width": 640, "height": 360},
  "events": [
    {"type": "log", "message": "=== editing_paired_autoscroll_hold_textarea ==="},
    {"type": "mouse_down", "target": {"selector": "#auto-area", "offset_x": 4, "offset_y": 8}, "button": 0},
    {"type": "mouse_move", "target": {"selector": "#auto-area", "offset_x": 170, "offset_y": 54}},
    {"type": "advance_time", "ms": 160, "steps": 10},
    {"type": "assert_event_log", "contains": "\"type\":\"editing.autoscroll\"", "min": 2},
    {"type": "assert_event_log", "contains": "\"operation\":\"start\"", "min": 1},
    {"type": "assert_event_log", "contains": "\"operation\":\"tick\"", "min": 1},
    {"type": "mouse_up", "target": {"selector": "#auto-area", "offset_x": 170, "offset_y": 54}, "button": 0},
    {"type": "assert_event_log", "contains": "\"operation\":\"stop\"", "min": 1},
    {"type": "assert_editing_selection", "target": {"selector": "#auto-area"}, "start": 0, "end": 35}
  ]
}
