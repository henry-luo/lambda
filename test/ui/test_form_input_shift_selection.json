{
  "name": "Form input - Shift navigation extends selection through unified editing surface",
  "html": "test/ui/test_form_input.html",
  "viewport": {"width": 600, "height": 600},
  "events": [
    {"type": "log", "message": "=== form_input_shift_selection ==="},

    {"type": "click", "target": {"selector": "#name"}},
    {"type": "wait", "ms": 80},
    {"type": "type", "target": {"selector": "#name"}, "text": "abc"},
    {"type": "assert_value", "target": {"selector": "#name"}, "equals": "abc"},
    {"type": "assert_caret", "char_offset": 3},

    {"type": "key_press", "key": "Home"},
    {"type": "assert_caret", "char_offset": 0},

    {"type": "key_press", "key": "Right", "mods_str": "shift"},
    {"type": "assert_selection", "is_collapsed": false},

    {"type": "type", "target": {"selector": "#name"}, "text": "X"},
    {"type": "assert_value", "target": {"selector": "#name"}, "equals": "Xbc"},
    {"type": "assert_caret", "char_offset": 1},

    {"type": "key_press", "key": "End", "mods_str": "shift"},
    {"type": "assert_selection", "is_collapsed": false},

    {"type": "type", "target": {"selector": "#name"}, "text": "Y"},
    {"type": "assert_value", "target": {"selector": "#name"}, "equals": "XY"},
    {"type": "assert_state_dump", "reference": "test/ui/state/test_form_input_shift_selection_final.mark"}
  ]
}
