{
  "name": "editor4c: Bold toolbar toggles the mark OFF on a range that already has it",
  "_note": "Phase B — 4B's toolbar-bold-range applies bold. This covers the toggle-off path: apply bold, click Bold again, verify the leaf style no longer has font-weight:bold AND the toolbar button no longer has is-active. Uses the new `not_contains` assert_attribute predicate (Stage-4C addition to event_sim) so 'attribute absent' passes cleanly.",
  "html": "test/html/editor-dom.html",
  "viewport": {"width": 900, "height": 700},
  "events": [
    {"type": "wait", "ms": 250},
    {"type": "click", "target": {"selector": ".rdt-surface h1"}},
    {"type": "wait", "ms": 60},
    {"type": "key_combo", "key": "a", "mods_str": "super"},
    {"type": "wait", "ms": 80},
    {"type": "click", "target": {"selector": ".rdt-toolbar button[title=\"Bold (Cmd+B)\"]"}},
    {"type": "wait", "ms": 150},
    {"type": "assert_attribute", "target": {"selector": ".rdt-surface [data-source-path=\"0,0\"]"}, "attribute": "style", "contains": "font-weight:bold"},
    {"type": "click", "target": {"selector": ".rdt-toolbar button[title=\"Bold (Cmd+B)\"]"}},
    {"type": "wait", "ms": 150},
    {"type": "assert_attribute", "target": {"selector": ".rdt-surface [data-source-path=\"0,0\"]"}, "attribute": "style", "not_contains": "font-weight:bold"},
    {"type": "assert_attribute", "target": {"selector": ".rdt-toolbar button[title=\"Bold (Cmd+B)\"]"}, "attribute": "class", "not_contains": "is-active"}
  ]
}
