{
  "name": "editor4c: toolbar Italic applies to a selected range and lights the button active",
  "_note": "Phase B pilot — parallels 4B's toolbar-bold-range but for Italic. Verifies the second toolbar-mark path (bold's pipeline may not be shared with italic if commands diverge).",
  "html": "test/html/editor-dom.html",
  "viewport": {"width": 900, "height": 700},
  "events": [
    {"type": "wait", "ms": 250},
    {"type": "click", "target": {"selector": ".rdt-surface h1"}},
    {"type": "wait", "ms": 60},
    {"type": "key_combo", "key": "a", "mods_str": "super"},
    {"type": "wait", "ms": 80},
    {"type": "click", "target": {"selector": ".rdt-toolbar button[title=\"Italic (Cmd+I)\"]"}},
    {"type": "wait", "ms": 150},
    {"type": "assert_attribute", "target": {"selector": ".rdt-surface [data-source-path=\"0,0\"]"}, "attribute": "style", "contains": "font-style:italic"},
    {"type": "assert_attribute", "target": {"selector": ".rdt-toolbar button[title=\"Italic (Cmd+I)\"]"}, "attribute": "class", "contains": "is-active"}
  ]
}
