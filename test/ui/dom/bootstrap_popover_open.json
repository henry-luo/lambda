{
  "name": "Bootstrap Popover creates a Popper-positioned overlay from a native click",
  "html": "test/ui/dom/bootstrap_overlays.html",
  "events": [
    {"type": "click", "target": {"selector": "#popover-trigger"}},
    {"type": "assert_visible", "target": {"selector": ".popover"}, "visible": true},
    {"type": "assert_text", "target": {"selector": ".popover"}, "contains": "Popover body"},
    {"type": "assert_text", "target": {"selector": "#events"}, "contains": "popover-trigger:shown.bs.popover"}
  ]
}
