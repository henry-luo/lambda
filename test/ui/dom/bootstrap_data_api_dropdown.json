{
  "name": "Bootstrap data API dropdown opens and dismisses from native clicks",
  "html": "test/ui/dom/bootstrap_data_api.html",
  "events": [
    {"type": "click", "target": {"selector": "#dropdown-toggle"}},
    {"type": "assert_class", "target": {"selector": "#dropdown-menu"}, "class": "show"},
    {"type": "click", "target": {"selector": "#outside"}},
    {"type": "assert_class", "target": {"selector": "#dropdown-menu"}, "class": "show", "present": false},
    {"type": "assert_text", "target": {"selector": "#events"}, "contains": "dropdown-toggle:hidden.bs.dropdown"}
  ]
}
