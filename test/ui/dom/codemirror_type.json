    {"type": "type", "target": {"selector": ".cm-content"}, "text": "Radiant DOM2"},
    {"type": "wait", "ms": 30},
    {"type": "assert_text", "target": {"selector": ".cm-content"}, "equals": "Radiant DOM2"}
  ]
}
