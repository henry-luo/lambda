{
  "name": "jQuery UI Tabs activates panels through native clicks",
  "html": "test/ui/dom/jquery_ui_tabs.html",
  "events": [
    {"type": "wait", "ms": 30},
    {"type": "assert_class", "target": {"selector": "#tab-one"}, "class": "ui-tabs-anchor"},
    {"type": "assert_visible", "target": {"selector": "#tab-panel-one"}, "visible": true},
    {"type": "assert_visible", "target": {"selector": "#tab-panel-two"}, "visible": false},
    {"type": "click", "target": {"selector": "#tab-two"}},
    {"type": "wait", "ms": 30},
    {"type": "assert_class", "target": {"selector": "#tab-item-two"}, "class": "ui-tabs-active"},
    {"type": "assert_visible", "target": {"selector": "#tab-panel-one"}, "visible": false},
    {"type": "assert_visible", "target": {"selector": "#tab-panel-two"}, "visible": true},
    {"type": "assert_attr", "target": {"selector": "#tab-item-two"}, "attribute": "aria-selected", "equals": "true"},
    {"type": "assert_text", "target": {"selector": "#status"}, "equals": "tab-item-two"}
  ]
}
