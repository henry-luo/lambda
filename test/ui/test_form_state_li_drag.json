{
  "name": "Drag across multiple list items in Testing Instructions",
  "html": "test/layout/data/form/form_state.html",
  "events": [
    {"type": "log", "message": "Anchor on first li text"},
    {"type": "mouse_down", "target": {"text": "navigate between focusable"}, "button": 0},
    {"type": "wait", "ms": 20},
    {"type": "log", "message": "Drag to 2nd li"},
    {"type": "mouse_move", "target": {"text": "move the caret"}},
    {"type": "assert_selection", "is_collapsed": false, "check_dom": true},
    {"type": "log", "message": "Drag to 3rd li"},
    {"type": "mouse_move", "target": {"text": "extend selection"}},
    {"type": "assert_selection", "is_collapsed": false, "check_dom": true},
    {"type": "log", "message": "Drag to 4th li"},
    {"type": "mouse_move", "target": {"text": "select all text"}},
    {"type": "assert_selection", "is_collapsed": false, "check_dom": true},
    {"type": "assert_state_dump", "reference": "test/ui/state/test_form_state_li_drag_final.mark"},
    {"type": "render", "file": "./temp/form_state_li_drag.png"},
    {"type": "mouse_up", "target": {"text": "select all text"}, "button": 0}
  ]
}
