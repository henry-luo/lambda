{
  "name": "Form input - tripleclick selects all (F2)",
  "html": "test/ui/test_form_input.html",
  "viewport": {"width": 600, "height": 600},
  "events": [
    {"type": "log", "message": "=== form_input_tripleclick ==="},

    {"type": "click", "target": {"selector": "#name"}},
    {"type": "wait", "ms": 80},
    {"type": "paste_text", "target": {"selector": "#name"}, "text": "alpha beta"},
    {"type": "wait", "ms": 80},

    {"type": "tripleclick", "target": {"selector": "#name"}},
    {"type": "assert_selection", "is_collapsed": false},

    {"type": "key_combo", "key": "c", "mods_str": "super"},
    {"type": "assert_clipboard", "equals": "alpha beta"},
    {"type": "assert_state_dump", "reference": "test/ui/state/test_form_input_tripleclick_final.mark"}
  ]
}
