{
  "name": "Todo2 textarea editing",
  "html": "test/lambda/ui/todo2.ls",
  "viewport": {"width": 900, "height": 700},
  "events": [
    {"type": "assert_count", "target": {"selector": ".todo-item"}, "min_count": 3, "comment": "Initial items visible"},
    {"type": "click", "target": {"selector": ".todo-text", "index": 0}, "comment": "Click first item text to edit"},
    {"type": "wait", "ms": 200},
    {"type": "assert_count", "target": {"selector": ".inline-edit"}, "count": 1, "comment": "Title input appears"},
    {"type": "assert_count", "target": {"selector": "textarea"}, "count": 1, "comment": "Notes textarea appears"},
    {"type": "key_press", "key": "Escape", "comment": "Exit editing via Escape on textarea"},
    {"type": "wait", "ms": 200},
    {"type": "assert_count", "target": {"selector": "textarea"}, "count": 0, "comment": "Textarea disappears after Escape"},
    {"type": "click", "target": {"selector": ".todo-notes", "index": 0}, "comment": "Click notes text to open editor"},
    {"type": "wait", "ms": 200},
    {"type": "assert_count", "target": {"selector": "textarea"}, "count": 1, "comment": "Textarea appears when clicking notes"}
  ]
}
