{
  "name": "RTE caret clicks in block margin",
  "html": "test/ui/rte_prototype.ls",
  "viewport": {"width": 980, "height": 720},
  "events": [
    {"type": "wait", "ms": 250},
    {"type": "assert_text", "target": {"selector": "#status"}, "contains": "opened:./test/input/simple.md"},
    {"type": "mouse_move", "target": {"selector": "#doc h1", "offset_x": 180, "offset_y": 64}},
    {"type": "click", "target": {"selector": "#doc h1", "offset_x": 180, "offset_y": 64}},
    {"type": "assert_caret", "view_type": 1, "char_offset": 20},
    {"type": "assert_selection", "is_collapsed": true, "check_dom": true},
    {"type": "type", "text": "X"},
    {"type": "assert_text", "target": {"selector": "#doc h1"}, "equals": "Simple Markdown TestX"},
    {"type": "assert_text", "target": {"selector": "#doc p"}, "equals": "This is a simple markdown document for testing basic functionality."}
  ]
}
