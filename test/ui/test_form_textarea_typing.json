{
  "name": "Textarea - paste multi-line text (F1/F6)",
  "html": "test/ui/test_form_input.html",
  "viewport": {"width": 600, "height": 600},
  "events": [
    {"type": "log", "message": "=== form_textarea_typing ==="},
    {"type": "wait", "ms": 200},

    {"type": "click", "target": {"selector": "#bio"}},
    {"type": "wait", "ms": 80},
    {"type": "assert_focus", "target": {"selector": "#bio"}},

    {"type": "paste_text", "target": {"selector": "#bio"}, "text": "line one\nline two"},
    {"type": "wait", "ms": 80},
    {"type": "assert_value", "target": {"selector": "#bio"}, "equals": "line one\nline two"},

    {"type": "log", "message": "Triple-click then Cmd+C copies the line under caret"},
    {"type": "tripleclick", "target": {"selector": "#bio"}},
    {"type": "wait", "ms": 100},
    {"type": "assert_selection", "is_collapsed": false},
    {"type": "key_combo", "key": "c", "mods_str": "super"},
    {"type": "wait", "ms": 80},
    {"type": "assert_clipboard", "contains": "line"}
  ]
}
