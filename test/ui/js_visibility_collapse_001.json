{
  "name": "visibility-collapse-001: toggle column/row visibility via onclick",
  "html": "test/layout/data/css2.1/html4/visibility-collapse-001.htm",
  "description": "Clicking span/th elements toggles visibility:collapse on table columns and rows. The toggle() function adds/removes the 'collapse' CSS class.",
  "events": [
    {"type": "log", "message": "=== visibility-collapse-001: toggle table visibility ==="},
    {"type": "wait", "ms": 300},

    {"type": "log", "message": "Step 1: Verify initial state — col2 is visible"},
    {"type": "assert_visible", "target": {"selector": "#col2"}, "visible": true},

    {"type": "log", "message": "Step 2: Click 'Column 2' span to collapse col2"},
    {"type": "click", "target": {"text": "Column 2"}, "target_index": 0},
    {"type": "wait", "ms": 200},

    {"type": "log", "message": "Step 3: Verify col2 has class 'collapse'"},
    {"type": "assert_attribute", "target": {"selector": "#col2"}, "attribute": "class", "equals": "collapse", "assert_timeout": 500},

    {"type": "log", "message": "Step 4: Click 'Column 2' again to restore visibility"},
    {"type": "click", "target": {"text": "Column 2"}, "target_index": 0},
    {"type": "wait", "ms": 200},

    {"type": "log", "message": "Step 5: col2 class removed (className='' removes attribute)"},
    {"type": "wait", "ms": 100},

    {"type": "log", "message": "Step 6: Click 'Row 2' to collapse row2"},
    {"type": "click", "target": {"text": "Row 2"}, "target_index": 0},
    {"type": "wait", "ms": 200},

    {"type": "log", "message": "Step 7: Verify row2 has class 'collapse'"},
    {"type": "assert_attribute", "target": {"selector": "#row2"}, "attribute": "class", "equals": "collapse", "assert_timeout": 500},

    {"type": "log", "message": "=== visibility-collapse-001 complete ==="}
  ]
}
