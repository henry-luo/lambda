{
  "name": "Editing paired keyboard navigation - contenteditable line and document",
  "html": "test/ui/editing/contenteditable.html",
  "viewport": {"width": 640, "height": 360},
  "events": [
    {"type": "log", "message": "=== editing_paired_keyboard_nav_contenteditable ==="},
    {"type": "set_editing_selection", "target": {"selector": "#surface"}, "start": 2, "end": 2},
    {"type": "key_press", "key": "End"},
    {"type": "assert_editing_selection", "target": {"selector": "#surface"}, "start": 4, "end": 4},
    {"type": "key_press", "key": "Home"},
    {"type": "assert_editing_selection", "target": {"selector": "#surface"}, "start": 0, "end": 0},
    {"type": "key_press", "key": "Right", "mods_str": "shift"},
    {"type": "assert_selection", "is_collapsed": false, "check_dom": true},
    {"type": "assert_editing_selection", "target": {"selector": "#surface"}, "start": 0, "end": 1},
    {"type": "set_editing_selection", "target": {"selector": "#surface"}, "start": 2, "end": 2},
    {"type": "key_press", "key": "End", "mods_str": "super shift"},
    {"type": "assert_selection", "is_collapsed": false, "check_dom": true},
    {"type": "assert_editing_selection", "target": {"selector": "#surface"}, "start": 2, "end": 4}
  ]
}
