{
  "name": "Phase 5d: Hover pseudo-state tests",
  "html": "test/ui/test_phase5d_hover.html",
  "viewport": { "width": 800, "height": 600 },
  "events": [
    { "type": "log", "message": "=== Phase 5d: Hover state tests ===" },

    { "type": "log", "message": "--- Test 1: hover on #btn ---" },
    { "type": "assert_pixel", "target": { "selector": "#btn", "offset_x": 12, "offset_y": 12 }, "min_r": 45, "max_r": 65, "min_g": 140, "max_g": 165, "min_b": 205, "max_b": 230 },
    { "type": "mouse_move", "target": { "selector": "#btn" } },
    { "type": "render_pending" },
    { "type": "assert_pixel", "target": { "selector": "#btn", "offset_x": 12, "offset_y": 12 }, "force_render": false, "min_r": 30, "max_r": 50, "min_g": 115, "max_g": 140, "min_b": 170, "max_b": 200 },
    { "type": "assert_state", "target": { "selector": "#btn" }, "state": ":hover", "value": true },

    { "type": "log", "message": "--- Test 2: hover transfers from #btn to #link ---" },
    { "type": "mouse_move", "target": { "selector": "#link" } },
    { "type": "assert_state", "target": { "selector": "#link" }, "state": ":hover", "value": true },
    { "type": "assert_state", "target": { "selector": "#btn" }, "state": ":hover", "value": false },

    { "type": "log", "message": "--- Test 3: hover transfers back to #btn ---" },
    { "type": "mouse_move", "target": { "selector": "#btn" } },
    { "type": "assert_state", "target": { "selector": "#btn" }, "state": ":hover", "value": true },
    { "type": "assert_state", "target": { "selector": "#link" }, "state": ":hover", "value": false }
  ]
}
