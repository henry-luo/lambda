{
  "name": "Form beforeinput exposes cancellable target ranges",
  "html": "test/ui/test_form_beforeinput_target_ranges.html",
  "viewport": {"width": 600, "height": 320},
  "events": [
    {"type": "log", "message": "=== form_beforeinput_target_ranges ==="},
    {"type": "click", "target": {"selector": "#name"}},
    {"type": "wait", "ms": 80},
    {"type": "key_combo", "key": "a", "mods_str": "super"},
    {"type": "wait", "ms": 80},
    {"type": "type", "target": {"selector": "#name"}, "text": "X"},
    {"type": "assert_value", "target": {"selector": "#name"}, "equals": "abcd"},
    {"type": "assert_text", "target": {"selector": "#blocked-status"}, "equals": "blocked:insertText|1|name|0-4|X"},
    {"type": "assert_text", "target": {"selector": "#input-status"}, "equals": "input:none"},
    {"type": "type", "target": {"selector": "#name"}, "text": "Y"},
    {"type": "assert_text", "target": {"selector": "#before-status"}, "equals": "before:insertText|1|name|4-4|Y"},
    {"type": "assert_text", "target": {"selector": "#input-status"}, "equals": "input:insertText|Y|abcdY"},
    {"type": "assert_state_dump", "reference": "test/ui/state/test_form_beforeinput_target_ranges_final.mark"}
  ]
}
