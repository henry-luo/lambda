{
  "name": "Form password - reveal last inserted character expires on shared editing tick",
  "html": "test/ui/test_form_input.html",
  "viewport": {"width": 600, "height": 600},
  "events": [
    {"type": "log", "message": "=== form_password_reveal_timer ==="},
    {"type": "click", "target": {"selector": "#pwd"}},
    {"type": "wait", "ms": 80},
    {"type": "type", "target": {"selector": "#pwd"}, "text": "ab"},
    {"type": "assert_value", "target": {"selector": "#pwd"}, "equals": "ab"},
    {"type": "assert_password_reveal", "target": {"selector": "#pwd"}, "active": true, "start": 1, "end": 2},
    {"type": "click", "target": {"selector": "#name"}},
    {"type": "assert_password_reveal", "target": {"selector": "#pwd"}, "active": false},
    {"type": "click", "target": {"selector": "#pwd"}},
    {"type": "type", "target": {"selector": "#pwd"}, "text": "c"},
    {"type": "assert_value", "target": {"selector": "#pwd"}, "equals": "abc"},
    {"type": "assert_password_reveal", "target": {"selector": "#pwd"}, "active": true, "start": 2, "end": 3},
    {"type": "advance_time", "ms": 1500, "steps": 5},
    {"type": "assert_password_reveal", "target": {"selector": "#pwd"}, "active": false},
    {"type": "assert_event_log", "contains": "\"redacted\":true", "min": 1},
    {"type": "assert_state_dump", "reference": "test/ui/state/test_form_password_reveal_timer_final.mark"}
  ]
}
