{
  "name": "Rich text editor toolbar edits markdown document",
  "html": "test/ui/test_rich_text_editor.html",
  "description": "Opens test/input/simple.md into a small rich text editor, applies toolbar formatting actions, and verifies the edited document surface plus markdown serialization.",
  "viewport": {"width": 820, "height": 620},
  "events": [
    {"type": "log", "message": "=== rich_text_editor ==="},
    {"type": "wait", "ms": 250},

    {"type": "log", "message": "Verify markdown fixture opened into editor"},
    {"type": "assert_text", "target": {"selector": "#source-path"}, "contains": "test/input/simple.md"},
    {"type": "assert_text", "target": {"selector": "#doc-title"}, "contains": "Simple Markdown Test"},
    {"type": "assert_text", "target": {"selector": "#doc-paragraph"}, "contains": "simple markdown document"},
    {"type": "assert_count", "target": {"selector": "textarea#editor"}, "count": 1},

    {"type": "assert_value", "target": {"selector": "#editor"}, "contains": "Simple Markdown Test"},

    {"type": "log", "message": "Type into document editor and verify live value"},
    {"type": "click", "target": {"selector": "#editor"}},
    {"type": "assert_focus", "target": {"selector": "#editor"}},
    {"type": "type", "target": {"selector": "#editor"}, "text": " Keyboard typed text."},
    {"type": "wait", "ms": 100},
    {"type": "assert_value", "target": {"selector": "#editor"}, "contains": "Keyboard typed text."},
    {"type": "key_press", "key": "Left", "mods_str": "shift"},
    {"type": "key_press", "key": "Left", "mods_str": "shift"},
    {"type": "key_press", "key": "Left", "mods_str": "shift"},
    {"type": "key_press", "key": "Left", "mods_str": "shift"},
    {"type": "key_press", "key": "Left", "mods_str": "shift"},
    {"type": "key_press", "key": "Left", "mods_str": "shift"},
    {"type": "key_press", "key": "Left", "mods_str": "shift"},
    {"type": "key_press", "key": "Left", "mods_str": "shift"},
    {"type": "key_press", "key": "Left", "mods_str": "shift"},
    {"type": "key_press", "key": "Left", "mods_str": "shift"},
    {"type": "key_press", "key": "Left", "mods_str": "shift"},
    {"type": "key_press", "key": "Left", "mods_str": "shift"},
    {"type": "key_press", "key": "Left", "mods_str": "shift"},
    {"type": "key_press", "key": "Left", "mods_str": "shift"},
    {"type": "key_press", "key": "Left", "mods_str": "shift"},
    {"type": "key_press", "key": "Left", "mods_str": "shift"},
    {"type": "key_press", "key": "Left", "mods_str": "shift"},
    {"type": "key_press", "key": "Left", "mods_str": "shift"},
    {"type": "key_press", "key": "Left", "mods_str": "shift"},
    {"type": "key_press", "key": "Left", "mods_str": "shift"},
    {"type": "key_press", "key": "Left", "mods_str": "shift"},
    {"type": "assert_selection", "is_collapsed": false},

    {"type": "log", "message": "Click formatting toolbar controls"},
    {"type": "click", "target": {"selector": "#btn-bold"}},
    {"type": "assert_attribute", "target": {"selector": "#btn-bold"}, "attribute": "class", "equals": "active", "assert_timeout": 500},
    {"type": "assert_text", "target": {"selector": "#status"}, "equals": "bold:on"},
    {"type": "assert_text", "target": {"selector": "#doc-paragraph"}, "contains": "Keyboard typed text."},
    {"type": "assert_text", "target": {"selector": ".selected-bold"}, "contains": "Keyboard typed text."},
    {"type": "assert_count", "target": {"selector": ".inserted-bold"}, "count": 1},
    {"type": "assert_text", "target": {"selector": "#markdown-output"}, "contains": "**bold text**"},
    {"type": "assert_text", "target": {"selector": "#markdown-output"}, "contains": "** Keyboard typed text.**"},

    {"type": "click", "target": {"selector": "#btn-italic"}},
    {"type": "assert_attribute", "target": {"selector": "#btn-italic"}, "attribute": "class", "equals": "active", "assert_timeout": 500},
    {"type": "assert_count", "target": {"selector": ".inserted-italic"}, "count": 1},
    {"type": "assert_text", "target": {"selector": "#markdown-output"}, "contains": "*italic text*"},

    {"type": "click", "target": {"selector": "#btn-underline"}},
    {"type": "assert_attribute", "target": {"selector": "#btn-underline"}, "attribute": "class", "equals": "active", "assert_timeout": 500},
    {"type": "assert_count", "target": {"selector": ".inserted-underline"}, "count": 1},
    {"type": "assert_text", "target": {"selector": "#markdown-output"}, "contains": "<u>underlined text</u>"},

    {"type": "click", "target": {"selector": "#btn-list"}},
    {"type": "assert_attribute", "target": {"selector": "#btn-list"}, "attribute": "class", "equals": "active", "assert_timeout": 500},
    {"type": "assert_count", "target": {"selector": "#doc-list li"}, "count": 2},
    {"type": "assert_text", "target": {"selector": "#markdown-output"}, "contains": "- Toolbar list item"},

    {"type": "log", "message": "Insert text through toolbar command"},
    {"type": "click", "target": {"selector": "#btn-insert"}},
    {"type": "assert_text", "target": {"selector": "#doc-paragraph"}, "contains": "Edited by UI automation."},
    {"type": "assert_text", "target": {"selector": "#markdown-output"}, "contains": "Edited by UI automation."},
    {"type": "assert_text", "target": {"selector": "#status"}, "equals": "insert-text"},

    {"type": "log", "message": "=== rich_text_editor complete ==="}
  ]
}
