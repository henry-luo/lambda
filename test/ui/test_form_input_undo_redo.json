{
  "name": "Form input - undo and redo restore text-control history",
  "html": "test/ui/test_form_input.html",
  "viewport": {"width": 600, "height": 600},
  "events": [
    {"type": "log", "message": "=== form_input_undo_redo ==="},

    {"type": "click", "target": {"selector": "#name"}},
    {"type": "assert_focus", "target": {"selector": "#name"}},

    {"type": "type", "target": {"selector": "#name"}, "text": "abc"},
    {"type": "assert_value", "target": {"selector": "#name"}, "equals": "abc"},
    {"type": "assert_caret", "char_offset": 3},

    {"type": "key_combo", "key": "z", "mods_str": "super"},
    {"type": "assert_value", "target": {"selector": "#name"}, "equals": "ab"},
    {"type": "assert_caret", "char_offset": 2},

    {"type": "key_combo", "key": "z", "mods_str": "super"},
    {"type": "assert_value", "target": {"selector": "#name"}, "equals": "a"},
    {"type": "assert_caret", "char_offset": 1},

    {"type": "key_combo", "key": "z", "mods_str": "super+shift"},
    {"type": "assert_value", "target": {"selector": "#name"}, "equals": "ab"},
    {"type": "assert_caret", "char_offset": 2},

    {"type": "key_combo", "key": "y", "mods_str": "ctrl"},
    {"type": "assert_value", "target": {"selector": "#name"}, "equals": "abc"},
    {"type": "assert_caret", "char_offset": 3},

    {"type": "assert_event_log", "contains": "\"type\":\"editing.history\"", "min": 4},
    {"type": "assert_event_log", "contains": "\"action\":\"push\"", "min": 3},
    {"type": "assert_event_log", "contains": "\"input_type\":\"insertText\"", "min": 3},
    {"type": "assert_event_log", "contains": "\"owned_by\":\"radiant\"", "min": 4},
    {"type": "assert_state_dump", "reference": "test/ui/state/test_form_input_undo_redo_final.mark"}
  ]
}
