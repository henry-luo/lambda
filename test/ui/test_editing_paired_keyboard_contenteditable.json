{
  "name": "Editing paired keyboard - contenteditable selection navigation",
  "html": "test/ui/editing/contenteditable.html",
  "viewport": {"width": 640, "height": 360},
  "events": [
    {"type": "log", "message": "=== editing_paired_keyboard_contenteditable ==="},
    {"type": "wait", "ms": 150},
    {"type": "click", "target": {"selector": "#surface"}},
    {"type": "wait", "ms": 60},
    {"type": "key_combo", "key": "a", "mods_str": "super"},
    {"type": "wait", "ms": 80},
    {"type": "assert_editing_event", "event": "editing.transaction", "inputType": "selectAll", "surface": "contenteditable", "operation": "selectAll", "min": 2},
    {"type": "type", "target": {"selector": "#surface"}, "text": "Q"},
    {"type": "wait", "ms": 80},
    {"type": "assert_text", "target": {"selector": "#before-log"}, "contains": "before:insertText|Q"},
    {"type": "assert_text", "target": {"selector": "#surface"}, "equals": "Q"}
  ]
}
