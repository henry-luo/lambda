{
  "name": "Editing paired keyboard - textarea selection navigation",
  "html": "test/ui/editing/textarea.html",
  "viewport": {"width": 640, "height": 380},
  "events": [
    {"type": "log", "message": "=== editing_paired_keyboard_textarea ==="},
    {"type": "click", "target": {"selector": "#surface"}},
    {"type": "paste_text", "target": {"selector": "#surface"}, "text": "ab\ncd"},
    {"type": "assert_text", "target": {"selector": "#input-log"}, "equals": "input:insertFromPaste|ab\ncd|ab\ncd"},
    {"type": "click", "target": {"selector": "#surface"}},
    {"type": "wait", "ms": 60},
    {"type": "key_combo", "key": "a", "mods_str": "super"},
    {"type": "wait", "ms": 80},
    {"type": "type", "target": {"selector": "#surface"}, "text": "Z"},
    {"type": "assert_text", "target": {"selector": "#input-log"}, "equals": "input:insertText|Z|Z"}
  ]
}
