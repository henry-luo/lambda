{
  "name": "Editing paired clipboard cut - textarea deleteByCut",
  "html": "test/ui/editing/textarea.html",
  "viewport": {"width": 640, "height": 360},
  "events": [
    {"type": "log", "message": "=== editing_paired_clipboard_cut_textarea ==="},
    {"type": "assert_editing_value", "target": {"selector": "#nav-area"}, "equals": "ab\ncd\nef"},
    {"type": "set_editing_selection", "target": {"selector": "#nav-area"}, "start": 0, "end": 3},
    {"type": "key_combo", "key": "x", "mods_str": "super"},
    {"type": "assert_editing_value", "target": {"selector": "#nav-area"}, "equals": "cd\nef"},
    {"type": "assert_editing_event", "event": "editing.beforeinput", "inputType": "deleteByCut", "surface": "text_control", "prevented": false, "min": 1},
    {"type": "assert_event_log", "contains": "\"operation\":\"cut\"", "min": 1},
    {"type": "assert_event_log", "contains": "\"text_len\":3", "min": 1}
  ]
}
