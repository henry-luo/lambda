{
  "name": "Form textarea - Shift navigation extends selection through unified editing surface",
  "html": "test/ui/test_form_input.html",
  "viewport": {"width": 600, "height": 600},
  "events": [
    {"type": "log", "message": "=== form_textarea_shift_selection ==="},

    {"type": "click", "target": {"selector": "#bio"}},
    {"type": "wait", "ms": 80},
    {"type": "paste_text", "target": {"selector": "#bio"}, "text": "ab\ncd"},
    {"type": "assert_value", "target": {"selector": "#bio"}, "equals": "ab\ncd"},
    {"type": "assert_caret", "char_offset": 5},

    {"type": "key_press", "key": "Home"},
    {"type": "assert_caret", "char_offset": 3},

    {"type": "key_press", "key": "Right", "mods_str": "shift"},
    {"type": "assert_selection", "is_collapsed": false},

    {"type": "type", "target": {"selector": "#bio"}, "text": "X"},
    {"type": "assert_value", "target": {"selector": "#bio"}, "equals": "ab\nXd"},
    {"type": "assert_caret", "char_offset": 4},

    {"type": "key_press", "key": "End", "mods_str": "shift"},
    {"type": "assert_selection", "is_collapsed": false},

    {"type": "type", "target": {"selector": "#bio"}, "text": "Y"},
    {"type": "assert_value", "target": {"selector": "#bio"}, "equals": "ab\nXY"},
    {"type": "assert_state_dump", "reference": "test/ui/state/test_form_textarea_shift_selection_final.mark"}
  ]
}
