{
  "name": "Phase 2c: Form assertions - assert_value, assert_checked, assert_state",
  "html": "test/ui/test_form_assertions.html",
  "description": "Tests the new Phase 2 assertion types: assert_value (form field values), assert_checked (checkbox/radio state), and assert_state (pseudo-state queries like :hover, :active, :focus, :checked).",
  "events": [
    {"type": "log", "message": "=== Phase 2c: Form assertion tests ==="},
    {"type": "wait", "ms": 300},

    {"type": "log", "message": "--- A. assert_value: verify initial input values ---"},
    {"type": "assert_value", "target": {"selector": "input#email"}, "equals": "user@test.com"},
    {"type": "assert_value", "target": {"selector": "input#name"}, "equals": "Alice"},
    {"type": "assert_value", "target": {"selector": "input#empty"}, "equals": ""},

    {"type": "log", "message": "--- B. assert_checked: verify initial checkbox/radio states ---"},
    {"type": "assert_checked", "target": {"selector": "input#agree"}, "checked": true},
    {"type": "assert_checked", "target": {"selector": "input#newsletter"}, "checked": false},
    {"type": "assert_checked", "target": {"selector": "input#radio-a"}, "checked": true},
    {"type": "assert_checked", "target": {"selector": "input#radio-b"}, "checked": false},

    {"type": "log", "message": "--- C. assert_state: verify pseudo-states before interaction ---"},
    {"type": "assert_state", "target": {"selector": "#btn-submit"}, "state": ":hover", "value": false},
    {"type": "assert_state", "target": {"selector": "#btn-submit"}, "state": ":active", "value": false},
    {"type": "assert_state", "target": {"selector": "input#agree"}, "state": ":checked", "value": true},
    {"type": "assert_state", "target": {"selector": "input#newsletter"}, "state": ":checked", "value": false},

    {"type": "log", "message": "--- D. Click checkbox to toggle, then re-assert ---"},
    {"type": "click", "target": {"selector": "input#newsletter"}},
    {"type": "wait", "ms": 100},
    {"type": "assert_checked", "target": {"selector": "input#newsletter"}, "checked": true},
    {"type": "assert_state", "target": {"selector": "input#newsletter"}, "state": ":checked", "value": true},

    {"type": "log", "message": "--- E. Click radio-b to switch, verify both states ---"},
    {"type": "click", "target": {"selector": "input#radio-b"}},
    {"type": "wait", "ms": 100},
    {"type": "assert_checked", "target": {"selector": "input#radio-b"}, "checked": true},
    {"type": "assert_checked", "target": {"selector": "input#radio-a"}, "checked": false},

    {"type": "log", "message": "--- F. assert_text on heading and paragraph ---"},
    {"type": "assert_text", "target": {"selector": "h2"}, "equals": "Form Test"},
    {"type": "assert_text", "target": {"selector": ".info"}, "contains": "testing"},

    {"type": "log", "message": "--- G. assert_visible on visible and hidden elements ---"},
    {"type": "assert_visible", "target": {"selector": "#btn-submit"}, "visible": true},
    {"type": "assert_visible", "target": {"selector": ".hidden-box"}, "visible": false},

    {"type": "render", "file": "./temp/phase2c_form_assertions.png"}
  ]
}
