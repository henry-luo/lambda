{
  "name": "Editing paired drop - textarea move preserves multiline payload",
  "html": "test/ui/editing/textarea.html",
  "viewport": {"width": 640, "height": 360},
  "events": [
    {"type": "log", "message": "=== editing_paired_drop_textarea ==="},
    {"type": "wait", "ms": 150},
    {"type": "set_editing_value", "target": {"selector": "#surface"}, "text": "ab\ncd"},
    {"type": "editing_text_drag_drop",
     "target": {"selector": "#surface", "start": 0, "end": 3},
     "to_target": {"selector": "#surface", "start": 5, "end": 5},
     "text": "ab\n",
     "move": true},
    {"type": "wait", "ms": 80},
    {"type": "assert_text", "target": {"selector": "#before-log"}, "contains": "before:insertFromDrop|ab"},
    {"type": "assert_text", "target": {"selector": "#before-log"}, "contains": "|1|2-2"},
    {"type": "assert_text", "target": {"selector": "#input-log"}, "contains": "cdab"},
    {"type": "assert_text", "target": {"selector": "#transfer-log"}, "equals": "transfer:dt:none"},
    {"type": "assert_editing_event", "event": "editing.beforeinput", "inputType": "deleteByDrag", "surface": "text_control", "min": 1},
    {"type": "assert_editing_event", "event": "editing.beforeinput", "inputType": "insertFromDrop", "surface": "text_control", "min": 1}
  ]
}
