{
  "name": "Todo add item via text input",
  "html": "test/lambda/ui/todo.ls",
  "viewport": {"width": 600, "height": 800},
  "events": [
    {"type": "log", "message": "=== Todo Add Item Test ==="},
    {"type": "wait", "ms": 200},

    {"type": "log", "message": "Step 1: Verify initial item count (3+3+2=8)"},
    {"type": "assert_count", "target": {"selector": ".todo-item"}, "count": 8},

    {"type": "log", "message": "Step 2: Verify add button exists on first list"},
    {"type": "assert_text", "target": {"selector": ".add-btn"}, "contains": "Add"},

    {"type": "log", "message": "Step 3: Verify input field exists"},
    {"type": "assert_count", "target": {"selector": ".new-item-input"}, "count": 3},

    {"type": "log", "message": "Step 4: Click input field to focus it"},
    {"type": "click", "target": {"selector": ".new-item-input"}},
    {"type": "wait", "ms": 100},

    {"type": "log", "message": "Step 5: Type new item text"},
    {"type": "type", "target": {"selector": ".new-item-input"}, "text": "Write tests"},
    {"type": "wait", "ms": 200},

    {"type": "log", "message": "Step 6: Click Add button"},
    {"type": "click", "target": {"selector": ".add-btn"}},
    {"type": "wait", "ms": 200},

    {"type": "log", "message": "Step 7: Verify item count increased (8+1=9)"},
    {"type": "assert_count", "target": {"selector": ".todo-item"}, "count": 9},

    {"type": "log", "message": "Step 8: Verify Work list count updated (was 1/3, now 1/4)"},
    {"type": "assert_text", "target": {"selector": ".list-count"}, "contains": "1/4"},

    {"type": "log", "message": "=== Todo Add Item Test Complete ==="}
  ]
}
