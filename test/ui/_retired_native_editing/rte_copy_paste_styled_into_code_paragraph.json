{
  "name": "RTE copy paste styled inline into code paragraph preserves siblings",
  "html": "test/ui/rte_prototype.ls",
  "viewport": {"width": 1200, "height": 800},
  "events": [
    {"type": "wait", "ms": 250},
    {"type": "mouse_drag", "target": {"text": "bold text"}, "to_target": {"text": "italic text"}, "button": 0},
    {"type": "wait", "ms": 80},
    {"type": "assert_selection", "is_collapsed": false, "check_dom": true},
    {"type": "key_combo", "key": "c", "mods_str": "ctrl"},
    {"type": "wait", "ms": 80},
    {"type": "assert_clipboard", "contains": "bold text"},
    {"type": "click", "target": {"text": "and a code block:", "offset_x": 330, "offset_y": 10}},
    {"type": "key_combo", "key": "v", "mods_str": "ctrl"},
    {"type": "wait", "ms": 140},
    {"type": "assert_text", "target": {"selector": "#doc"}, "contains": "Here's some"},
    {"type": "assert_text", "target": {"selector": "#doc"}, "contains": "inline code"},
    {"type": "assert_text", "target": {"selector": "#doc"}, "contains": "code block:"},
    {"type": "assert_text", "target": {"selector": "#doc"}, "contains": "Here's some inline code"},
    {"type": "assert_count", "target": {"selector": "#doc strong"}, "count": 2},
    {"type": "assert_count", "target": {"selector": "#doc em"}, "count": 2},
    {"type": "assert_selection", "is_collapsed": true, "check_dom": true}
  ]
}
