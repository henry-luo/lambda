{
  "name": "Contenteditable scroll container click targets nested rich editor",
  "html": "test/ui/editing/contenteditable.html",
  "viewport": { "width": 640, "height": 420 },
  "events": [
    { "type": "click", "target": { "selector": "#surface", "offset_x": 24, "offset_y": 16 } },
    { "type": "click", "target": { "selector": "#auto-scroll", "offset_x": 42, "offset_y": 20 } },
    { "type": "assert_caret", "view_type": 1 },
    { "type": "type", "text": "Q" },
    { "type": "assert_text", "target": { "selector": "#auto-rich" }, "contains": "Q" },
    { "type": "assert_text", "target": { "selector": "#input-log" }, "equals": "input:none" }
  ]
}
