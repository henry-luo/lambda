{
  "name": "Rich contenteditable history shortcuts emit beforeinput intents",
  "html": "test/ui/test_editing_history_rich.html",
  "viewport": {"width": 640, "height": 360},
  "events": [
    {"type": "log", "message": "=== editing_history_rich ==="},
    {"type": "wait", "ms": 150},
    {"type": "click", "target": {"selector": "#cancel-host", "offset_x": 86, "offset_y": 20}},
    {"type": "wait", "ms": 80},
    {"type": "key_combo", "key": "z", "mods_str": "ctrl"},
    {"type": "wait", "ms": 80},
    {"type": "assert_text", "target": {"selector": "#log"}, "equals": "historyUndo"},
    {"type": "click", "target": {"selector": "#cancel-host", "offset_x": 86, "offset_y": 20}},
    {"type": "wait", "ms": 80},
    {"type": "key_combo", "key": "y", "mods_str": "ctrl"},
    {"type": "wait", "ms": 80},
    {"type": "assert_text", "target": {"selector": "#log"}, "equals": "historyRedo"},

    {"type": "click", "target": {"selector": "#restore-host", "offset_x": 84, "offset_y": 20}},
    {"type": "wait", "ms": 80},
    {"type": "type", "text": "X"},
    {"type": "wait", "ms": 80},
    {"type": "assert_text", "target": {"selector": "#restore-host"}, "contains": "X"},
    {"type": "key_combo", "key": "z", "mods_str": "ctrl"},
    {"type": "wait", "ms": 80},
    {"type": "assert_text", "target": {"selector": "#restore-host"}, "equals": "undo seed"},
    {"type": "key_combo", "key": "y", "mods_str": "ctrl"},
    {"type": "wait", "ms": 80},
    {"type": "assert_text", "target": {"selector": "#restore-host"}, "contains": "X"},

    {"type": "assert_event_log", "contains": "\"owned_by\":\"consumer\"", "min": 2},
    {"type": "assert_event_log", "contains": "\"input_type\":\"historyUndo\"", "min": 1},
    {"type": "assert_event_log", "contains": "\"input_type\":\"historyRedo\"", "min": 1},
    {"type": "assert_editing_event", "event": "editing.transaction", "inputType": "historyUndo", "surface": "contenteditable", "operation": "history", "min": 2},
    {"type": "assert_editing_event", "event": "editing.transaction", "inputType": "historyRedo", "surface": "contenteditable", "operation": "history", "min": 2}
  ]
}
