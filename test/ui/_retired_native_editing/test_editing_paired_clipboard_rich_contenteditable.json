{
  "name": "Editing paired clipboard - rich contenteditable copy cut paste",
  "html": "test/ui/editing/contenteditable.html",
  "viewport": {"width": 760, "height": 520},
  "events": [
    {"type": "log", "message": "=== editing_paired_clipboard_rich_contenteditable ==="},
    {"type": "wait", "ms": 150},
    {"type": "set_editing_selection", "target": {"text": "strong labels"}, "start": 0, "end": 13},
    {"type": "key_combo", "key": "c", "mods_str": "super"},
    {"type": "assert_clipboard", "equals": "strong labels"},
    {"type": "assert_clipboard", "mime": "text/html", "contains": "<b>strong labels</b>"},
    {"type": "key_combo", "key": "x", "mods_str": "super"},
    {"type": "assert_clipboard", "equals": "strong labels"},
    {"type": "assert_clipboard", "mime": "text/html", "contains": "<b>strong labels</b>"},
    {"type": "assert_selection", "is_collapsed": true, "check_dom": true},
    {"type": "assert_caret", "char_offset": 0},
    {"type": "assert_text", "target": {"selector": "#auto-rich"}, "contains": "This paragraph mixes , inline notes"},
    {"type": "paste_text", "text": "strong labels"},
    {"type": "assert_text", "target": {"selector": "#auto-rich"}, "contains": "This paragraph mixes strong labels, inline notes"},
    {"type": "assert_editing_event", "event": "editing.transaction", "inputType": "deleteByCut", "surface": "contenteditable", "min": 2},
    {"type": "assert_editing_event", "event": "editing.transaction", "inputType": "insertFromPaste", "surface": "contenteditable", "min": 2}
  ]
}
