{
  "name": "Editing paired logging - contenteditable intent records",
  "html": "test/ui/editing/contenteditable.html",
  "viewport": {"width": 640, "height": 420},
  "events": [
    {"type": "log", "message": "=== editing_paired_logging_contenteditable ==="},
    {"type": "wait", "ms": 150},
    {"type": "click", "target": {"selector": "#surface"}},
    {"type": "type", "target": {"selector": "#surface"}, "text": "L"},
    {"type": "wait", "ms": 80},
    {"type": "assert_text", "target": {"selector": "#input-log"}, "contains": "input:insertText|L|seed"},
    {"type": "assert_text", "target": {"selector": "#before-log"}, "contains": "before:insertText|L|1|4-4"},
    {"type": "assert_text", "target": {"selector": "#input-log"}, "contains": "input:insertText|L|seedL|ranges:1|4-4"},
    {"type": "assert_event_log", "contains": "\"type\":\"editing.intent\"", "min": 1},
    {"type": "assert_event_log", "contains": "\"type\":\"editing.beforeinput\"", "min": 1},
    {"type": "assert_event_log", "contains": "\"type\":\"editing.input\"", "min": 1},
    {"type": "assert_event_log", "contains": "\"type\":\"editing.mutation\"", "min": 1},
    {"type": "assert_event_log", "contains": "\"operation\":\"insert\"", "min": 1},
    {"type": "assert_event_log", "contains": "\"old_len\":4", "min": 1},
    {"type": "assert_event_log", "contains": "\"new_len\":5", "min": 1},
    {"type": "assert_event_log", "contains": "\"type\":\"editing.transaction\"", "min": 2},
    {"type": "assert_event_log", "contains": "\"transaction_id\"", "min": 2},
    {"type": "assert_event_log", "contains": "\"target_ranges\"", "min": 1},
    {"type": "assert_event_log", "contains": "\"selection_before\"", "min": 1},
    {"type": "assert_event_log", "contains": "\"selection_after\"", "min": 1},
    {"type": "assert_event_log", "contains": "\"history_boundary\":false", "min": 1},
    {"type": "assert_event_log", "contains": "\"coalescable\":true", "min": 1},
    {"type": "assert_event_log", "contains": "\"coalesce_key\":\"insertText\"", "min": 1},
    {"type": "assert_event_log", "contains": "\"summary\"", "min": 1},
    {"type": "assert_event_log", "contains": "\"phase\":\"begin\"", "min": 1},
    {"type": "assert_event_log", "contains": "\"phase\":\"commit\"", "min": 1},
    {"type": "assert_event_log", "contains": "\"owned_by\":\"consumer\"", "min": 1}
  ]
}
