{
  "name": "Editing paired clipboard - textarea paste and copy",
  "html": "test/ui/editing/textarea.html",
  "viewport": {"width": 640, "height": 380},
  "events": [
    {"type": "log", "message": "=== editing_paired_clipboard_textarea ==="},
    {"type": "wait", "ms": 150},
    {"type": "click", "target": {"selector": "#surface"}},
    {"type": "paste_text", "target": {"selector": "#surface"}, "text": "clip\ntext"},
    {"type": "wait", "ms": 80},
    {"type": "assert_text", "target": {"selector": "#input-log"}, "equals": "input:insertFromPaste|clip\ntext|clip\ntext"},
    {"type": "assert_text", "target": {"selector": "#transfer-log"}, "equals": "transfer:dt:none"},
    {"type": "key_combo", "key": "a", "mods_str": "super"},
    {"type": "wait", "ms": 80},
    {"type": "key_combo", "key": "c", "mods_str": "super"},
    {"type": "wait", "ms": 80},
    {"type": "assert_clipboard", "equals": "clip\ntext"}
  ]
}
