{
  "name": "DOM mutation innerHTML parent retains child prunes",
  "html": "test/ui/dom_mutation_innerhtml_parent_retains_child_prunes.html",
  "viewport": {"width": 640, "height": 380},
  "events": [
    {"type": "scroll", "x": 80, "y": 70, "dx": 0, "dy": -5},
    {"type": "assert_state_store", "target": {"selector": "#host"}, "view_state": true, "kind": "scroll", "view_scroll_y": 50, "tolerance": 80},
    {"type": "snapshot_state_store", "name": "host-scroll", "target": {"selector": "#host"}},
    {"type": "click", "target": {"selector": "#victim"}},
    {"type": "assert_state_store", "target": {"selector": "#victim"}, "view_state": true, "kind": "form", "weak_ref": true},
    {"type": "snapshot_state_store", "name": "removed-child", "target": {"selector": "#victim"}},
    {"type": "click", "target": {"selector": "#replace"}},
    {"type": "assert_count", "target": {"selector": "#victim"}, "equals": 0},
    {"type": "assert_count", "target": {"selector": "#replacement"}, "equals": 1},
    {"type": "assert_reconcile_mode", "mode": "incremental", "reason": "eligible"},
    {"type": "assert_state_store_snapshot", "name": "host-scroll", "target": {"selector": "#host"}},
    {"type": "assert_state_store_snapshot", "name": "removed-child", "target": {"selector": "#victim"}, "removed": true}
  ]
}
