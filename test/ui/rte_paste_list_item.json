{
  "name": "RTE paste into list item",
  "html": "test/ui/rte_prototype.ls",
  "viewport": {"width": 1200, "height": 800},
  "events": [
    {"type": "wait", "ms": 250},
    {"type": "click", "target": {"text": "Item 1"}},
    {"type": "paste_text", "text": "ZZ"},
    {"type": "wait", "ms": 120},
    {"type": "assert_clipboard", "equals": "ZZ"},
    {"type": "assert_text", "target": {"selector": "#doc li"}, "contains": "ZZ"}
  ]
}
