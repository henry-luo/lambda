    {"type": "key_combo", "key": "c", "mods_str": "super"},
    {"type": "assert_clipboard", "contains": "Alpha words"},
    {"type": "assert_value", "target": {"selector": "#embedded-input"}, "equals": "inner"}
  ]
}
