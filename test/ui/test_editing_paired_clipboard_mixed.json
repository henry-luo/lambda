{
  "name": "Editing paired clipboard - mixed embedded input paste and host copy",
  "html": "test/ui/editing/mixed.html",
  "viewport": {"width": 760, "height": 380},
  "events": [
    {"type": "log", "message": "=== editing_paired_clipboard_mixed ==="},
    {"type": "click", "target": {"text": "Alpha"}},
