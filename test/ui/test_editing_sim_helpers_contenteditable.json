{
  "name": "Editing simulator helpers - contenteditable selection and event",
  "html": "test/ui/editing/contenteditable.html",
  "viewport": {"width": 640, "height": 360},
  "events": [
    {"type": "log", "message": "=== editing_sim_helpers_contenteditable ==="},
    {"type": "wait", "ms": 150},
    {"type": "set_editing_selection", "target": {"selector": "#surface"}, "start": 1, "end": 3},
    {"type": "assert_selection", "is_collapsed": false, "check_dom": true},
    {"type": "type", "target": {"selector": "#surface"}, "text": "Y"},
    {"type": "wait", "ms": 80},
    {"type": "assert_editing_value", "target": {"selector": "#surface"}, "equals": "sYd"},
    {"type": "assert_text", "target": {"selector": "#before-log"}, "contains": "before:insertText|Y|1|1-3"},
    {"type": "assert_editing_event", "event": "editing.beforeinput", "inputType": "insertText", "surface": "contenteditable", "min": 1}
  ]
}
