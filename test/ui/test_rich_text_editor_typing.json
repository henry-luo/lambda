{
  "name": "Rich text editor accepts typed text",
  "html": "test/ui/test_rich_text_editor_typing.html",
  "description": "Validates native typing into a markdown document editor shell with a formatting toolbar.",
  "viewport": {"width": 820, "height": 560},
  "events": [
    {"type": "log", "message": "=== rich_text_editor_typing ==="},
    {"type": "wait", "ms": 200},

    {"type": "assert_text", "target": {"selector": "#source-path"}, "contains": "test/input/simple.md"},
    {"type": "assert_count", "target": {"selector": "#toolbar button"}, "count": 4},
    {"type": "assert_value", "target": {"selector": "#editor"}, "contains": "Simple Markdown Test"},

    {"type": "click", "target": {"selector": "#editor"}},
    {"type": "assert_focus", "target": {"selector": "#editor"}},
    {"type": "type", "target": {"selector": "#editor"}, "text": " Typed text appears."},
    {"type": "wait", "ms": 80},
    {"type": "assert_value", "target": {"selector": "#editor"}, "contains": "Typed text appears."},

    {"type": "log", "message": "=== rich_text_editor_typing complete ==="}
  ]
}
