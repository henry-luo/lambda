{
  "name": "Editing paired IME - input composition order",
  "html": "test/ui/editing/input.html",
  "viewport": {"width": 640, "height": 360},
  "events": [
    {"type": "log", "message": "=== editing_paired_ime_input ==="},
    {"type": "click", "target": {"selector": "#surface"}},
    {"type": "ime_compose", "phase": "begin"},
    {"type": "ime_compose", "phase": "update", "preedit": "pre", "caret": 3},
    {"type": "ime_compose", "phase": "commit", "commit": "done"},
    {"type": "assert_text", "target": {"selector": "#composition-log"}, "contains": "compositionstart:|compositionupdate:pre|beforeinput:insertCompositionText:pre:1|input:insertCompositionText:pre:1|compositionend:done|beforeinput:insertFromComposition:done:0|input:insertFromComposition:done:0"},
    {"type": "assert_event_log", "contains": "\"type\":\"editing.composition\"", "min": 2}
  ]
}
