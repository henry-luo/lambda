    {"type": "set_editing_selection", "target": {"selector": "#nav-input"}, "start": 8, "end": 8},
    {"type": "key_press", "key": "Left", "mods_str": "alt"},
    {"type": "assert_editing_selection", "target": {"selector": "#nav-input"}, "start": 4, "end": 4},
    {"type": "key_press", "key": "Right", "mods_str": "alt"},
    {"type": "assert_editing_selection", "target": {"selector": "#nav-input"}, "start": 7, "end": 7},
    {"type": "key_press", "key": "Right", "mods_str": "super"},
    {"type": "assert_editing_selection", "target": {"selector": "#nav-input"}, "start": 13, "end": 13},
    {"type": "key_press", "key": "Left", "mods_str": "super"},
    {"type": "assert_editing_selection", "target": {"selector": "#nav-input"}, "start": 0, "end": 0},
    {"type": "key_press", "key": "Down", "mods_str": "shift"},
    {"type": "assert_editing_selection", "target": {"selector": "#nav-input"}, "start": 0, "end": 13}
