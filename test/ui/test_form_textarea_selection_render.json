{
  "name": "Form textarea - rendered selection reaches second line",
  "html": "test/ui/test_form_input.html",
  "viewport": {"width": 600, "height": 600},
  "events": [
    {"type": "log", "message": "=== form_textarea_selection_render ==="},

    {"type": "click", "target": {"selector": "#bio"}},
    {"type": "wait", "ms": 60},
    {"type": "paste_text", "target": {"selector": "#bio"}, "text": "asdf\nasdf"},
    {"type": "assert_value", "target": {"selector": "#bio"}, "equals": "asdf\nasdf"},

    {"type": "mouse_down", "target": {"selector": "#bio", "offset_x": 8, "offset_y": 8}, "button": "left"},
    {"type": "mouse_move", "target": {"selector": "#bio", "offset_x": 44, "offset_y": 30}},
    {"type": "assert_selection", "is_collapsed": false, "check_dom": true},
    {"type": "assert_form_selection", "target": {"selector": "#bio"}, "start": 0, "end": 9},
    {"type": "assert_pixel", "target": {"selector": "#bio", "offset_x": 12, "offset_y": 30}, "min_r": 170, "max_r": 190, "min_g": 205, "max_g": 225, "min_b": 245},
    {"type": "mouse_up", "target": {"selector": "#bio", "offset_x": 44, "offset_y": 30}, "button": "left"},

    {"type": "assert_selection", "is_collapsed": false, "check_dom": true},
    {"type": "assert_form_selection", "target": {"selector": "#bio"}, "start": 0, "end": 9},
    {"type": "assert_pixel", "target": {"selector": "#bio", "offset_x": 12, "offset_y": 30}, "min_r": 170, "max_r": 190, "min_g": 205, "max_g": 225, "min_b": 245},
    {"type": "assert_state_dump", "reference": "test/ui/state/test_form_textarea_selection_render_final.mark"}
  ]
}
