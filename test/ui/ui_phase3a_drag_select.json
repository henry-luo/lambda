     "to_x":   230, "to_y":   41,
     "button": 0},
    {"type": "assert_selection", "is_collapsed": false},

    {"type": "render", "file": "./temp/phase3a_drag_left.png"},

    {"type": "log", "message": "Dragging across center-aligned text (p at (32,104) 300x18, y_center=113)..."},
    {"type": "mouse_drag",
     "from_x": 95,  "from_y": 113,
     "to_x":   310, "to_y":   113,
     "button": 0},
    {"type": "assert_selection", "is_collapsed": false},

    {"type": "render", "file": "./temp/phase3a_drag_center.png"}
  ]
