{
  "name": "Form input - Tab key cycles focus (F3)",
  "html": "test/ui/test_form_input.html",
  "viewport": {"width": 600, "height": 600},
  "events": [
    {"type": "log", "message": "=== form_focus_tab ==="},

    {"type": "click", "target": {"selector": "#name"}},
    {"type": "assert_focus", "target": {"selector": "#name"}},

    {"type": "key_press", "key": "tab"},
    {"type": "assert_focus", "target": {"selector": "#code"}},

    {"type": "key_press", "key": "tab"},
    {"type": "assert_focus", "target": {"selector": "#pwd"}},

    {"type": "log", "message": "Tab visits readonly input but skips disabled input"},
    {"type": "key_press", "key": "tab"},
    {"type": "assert_focus", "target": {"selector": "#readonly-fld"}},

    {"type": "key_press", "key": "tab"},
    {"type": "assert_focus", "target": {"selector": "#bio"}},

    {"type": "log", "message": "Tab visits the submit button"},
    {"type": "key_press", "key": "tab"},
    {"type": "assert_focus", "target": {"selector": "#submit-btn"}},

    {"type": "log", "message": "Shift+Tab moves focus backward"},
    {"type": "key_press", "key": "tab", "mods_str": "shift"},
    {"type": "assert_focus", "target": {"selector": "#bio"}},

    {"type": "key_press", "key": "tab", "mods_str": "shift"},
    {"type": "assert_focus", "target": {"selector": "#readonly-fld"}},
    {"type": "assert_state_dump", "reference": "test/ui/state/test_form_focus_tab_final.mark"}
  ]
}
