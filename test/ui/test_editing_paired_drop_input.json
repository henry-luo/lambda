{
  "name": "Editing paired drop - input move emits deleteByDrag and insertFromDrop",
  "html": "test/ui/editing/input.html",
  "viewport": {"width": 640, "height": 360},
  "events": [
    {"type": "log", "message": "=== editing_paired_drop_input ==="},
    {"type": "set_editing_value", "target": {"selector": "#surface"}, "text": "seed"},
    {"type": "editing_text_drag_drop",
     "target": {"selector": "#surface", "start": 0, "end": 2},
     "to_target": {"selector": "#surface", "start": 4, "end": 4},
     "text": "se",
     "move": true},
    {"type": "assert_text", "target": {"selector": "#before-log"}, "contains": "before:insertFromDrop|se|1|2-2"},
    {"type": "assert_text", "target": {"selector": "#input-log"}, "contains": "input:insertFromDrop|se|edse"},
    {"type": "assert_text", "target": {"selector": "#transfer-log"}, "equals": "transfer:dt:none"},
    {"type": "assert_editing_event", "event": "editing.beforeinput", "inputType": "deleteByDrag", "surface": "text_control", "min": 1},
    {"type": "assert_editing_event", "event": "editing.beforeinput", "inputType": "insertFromDrop", "surface": "text_control", "min": 1}
  ]
}
