{
  "name": "Radiant view iframe remains sized after PDF then SVG target navigation",
  "viewport": { "width": 1200, "height": 600 },
  "events": [
    { "type": "assert_rect", "target": { "selector": "iframe[name=\"main_frame\"]" }, "width": 1186, "height": 602, "tolerance": 4 },
    { "type": "click", "target": { "selector": "a[href=\"../input/raw_commands_test.pdf\"]" } },
    { "type": "assert_rect", "target": { "selector": "iframe[name=\"main_frame\"]" }, "width": 1186, "height": 602, "tolerance": 4 },
    { "type": "click", "target": { "selector": "a[href=\"../layout/data/res/tiger.svg\"]" } },
    { "type": "assert_rect", "target": { "selector": "iframe[name=\"main_frame\"]" }, "width": 1186, "height": 602, "tolerance": 4 }
  ]
}
