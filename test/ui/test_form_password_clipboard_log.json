{
  "name": "Form password - clipboard event log redacts lengths",
  "html": "test/ui/test_form_input.html",
  "viewport": {"width": 600, "height": 600},
  "events": [
    {"type": "log", "message": "=== form_password_clipboard_log ==="},
    {"type": "wait", "ms": 200},
    {"type": "click", "target": {"selector": "#pwd"}},
    {"type": "wait", "ms": 80},
    {"type": "type", "target": {"selector": "#pwd"}, "text": "secret"},
    {"type": "wait", "ms": 80},
    {"type": "assert_value", "target": {"selector": "#pwd"}, "equals": "secret"},
    {"type": "key_combo", "key": "a", "mods_str": "super"},
    {"type": "wait", "ms": 80},
    {"type": "assert_selection", "is_collapsed": false},
    {"type": "key_combo", "key": "c", "mods_str": "super"},
    {"type": "wait", "ms": 80},
    {"type": "key_combo", "key": "v", "mods_str": "super"},
    {"type": "wait", "ms": 80},
    {"type": "assert_value", "target": {"selector": "#pwd"}, "equals": "secret"}
  ]
}
