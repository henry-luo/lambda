// Test: String Basic Operations
// Layer: 3 | Category: datatype | Covers: string length, concat, type, operations

len("hello")
len("abc")
let s1 = "hello" ++ " " ++ "world"
let s2 = "abc" ++ "def"
[s1, s2]
type("hello")
1
"hello" is string
"abc" == "abc"
"abc" != "def"
contains("hello world", "world")
starts_with("hello", "hel")
ends_with("hello", "llo")
let u = upper("hello")
let l = lower("HELLO")
[u, l]
