// Test: String Index Operations
// Layer: 3 | Category: function | Covers: index_of, last_index_of, contains, starts_with, ends_with

index_of("hello world", "world")
index_of("hello", "l")
index_of("hello", "xyz")
last_index_of("hello", "l")
contains("hello world", "world")
contains("hello", "xyz")
starts_with("hello world", "hello")
starts_with("hello", "xyz")
ends_with("hello world", "world")
ends_with("hello", "xyz")
