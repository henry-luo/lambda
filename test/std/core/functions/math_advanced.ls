// Test: Math Advanced
// Layer: 2 | Category: function | Covers: sqrt, log, exp, trig functions
// math is a built-in module, accessed via math.method() syntax

// ===== sqrt =====
math.sqrt(4.0)
math.sqrt(9.0)
math.sqrt(16.0)
math.sqrt(2.0)

// ===== log / log10 =====
math.log(1.0)
math.log10(100.0)
math.log10(1000.0)

// ===== exp =====
math.exp(0.0)
math.exp(1.0)

// ===== Trigonometric =====
math.sin(0.0)
math.cos(0.0)
math.tan(0.0)

// ===== Identities =====
round(math.sin(0.0))
round(math.cos(0.0))

// ===== sqrt of perfect squares =====
math.sqrt(1.0)
math.sqrt(25.0)
math.sqrt(100.0)
