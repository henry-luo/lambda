let x = 42; x
let a = 1; let b = 2; a + b
(let x2 = 5, x2 + 1)
(let a2 = 10, let b2 = 20, a2 + b2)
let n: int = 100; n
let arr = [1, 2, 3, 4, 5]; sum(arr)
let sqr = (a3: int, b3: int) => a3 + b3; sqr(3, 4)
