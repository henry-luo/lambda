{
  "version": 1,
  "file_exclusions": [
    {
      "pattern": "lambda/lambda-embed.h",
      "modules": ["lambda"],
      "reason": "Generated embedded-resource data is not maintained source code."
    },
    {
      "pattern": "lambda/*/parser.c",
      "modules": ["lambda"],
      "reason": "Tree-sitter parser.c files are generated parser tables and contain unavoidable repeated structures."
    }
  ],
  "block_exclusions": [
    {
      "id": "independent_event_enum_declarations",
      "modules": ["radiant"],
      "reason": "Lizard normalizes these independent sequential enums to the same token shape; sharing them would incorrectly couple separate event domains.",
      "regions": [
        {
          "file": "radiant/event.hpp",
          "start": "typedef enum  {",
          "end": "} EventType;"
        },
        {
          "file": "radiant/event.hpp",
          "start": "typedef enum InputIntentType {",
          "end": "} InputIntentType;"
        },
        {
          "file": "radiant/event.hpp",
          "start": "typedef enum SmFamily {",
          "end": "} SmFamily;"
        },
        {
          "file": "radiant/event.hpp",
          "start": "typedef enum SmEvent {",
          "end": "} SmEvent;"
        },
        {
          "file": "radiant/event.hpp",
          "start": "typedef enum SmInvariantId {",
          "end": "} SmInvariantId;"
        },
        {
          "file": "radiant/event_sim.hpp",
          "start": "enum SimEventType {",
          "end": "};"
        }
      ]
    },
    {
      "id": "independent_enum_name_switches",
      "modules": ["radiant"],
      "reason": "These enum-to-name switches belong to unrelated APIs; Lizard ignores the case labels that distinguish their domains.",
      "regions": [
        {
          "file": "radiant/editing_intent.cpp",
          "start": "const char* input_intent_type_name(",
          "end": "bool input_intent_is_dispatchable("
        },
