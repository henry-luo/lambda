          "end": "const char* editing_mode_name("
        },
        {
          "file": "radiant/editing.cpp",
          "start": "const char* editing_mode_name(",
          "end": "}"
        }
      ]
    },
    {
      "id": "independent_switch_case_inventories",
      "modules": ["radiant"],
      "reason": "These switches are independent membership inventories over unrelated intent, HTML tag, and display-op enums; Lizard discards the distinguishing case labels.",
      "regions": [
