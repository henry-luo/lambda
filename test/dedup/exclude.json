          "start": "void rdt_picture_get_size(",
          "end": "RdtPicture* rdt_picture_dup("
        }
      ]
    },
    {
      "id": "form_control_box_destructuring",
      "modules": ["radiant"],
      "reason": "Independent form painters unpack the same FormControlBox coordinates into readable local aliases; Lizard reports these prologues although each subsequent checkbox, radio, text, select, button, or range drawing body is distinct.",
