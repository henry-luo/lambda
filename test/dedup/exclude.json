    {
      "id": "declarative_state_transition_rows",
      "modules": ["radiant"],
      "reason": "The static state-machine schema intentionally uses one fixed aggregate row shape; converting readable data rows into macros or runtime builders would add code without reducing behavior duplication.",
      "allow_within_region": true,
      "regions": [
        {
          "file": "radiant/state_schema.cpp",
          "start": "static const StateTransitionRule RADIANT_STATE_RULES[] = {",
          "end": "#undef SM_RULE_TO"
        }
      ]
    },
    {
      "id": "flex_resolution_phase_loops",
      "modules": ["radiant"],
      "reason": "CSS Flexbox 9.7 requires sequential passes over one line's items; Lizard reports the identical loop guards while the pass bodies compute unrelated freeze, distribution, violation, and finalization state.",
      "allow_within_region": true,
      "regions": [
        {
          "file": "radiant/layout_flex.cpp",
          "start": "static void resolve_flexible_lengths(FlexContainerLayout* flex_layout, FlexLineInfo* line) {",
          "end": "static float flex_line_outer_main_size("
        }
      ]
    },
    {
      "id": "independent_flex_line_reductions",
      "modules": ["radiant"],
      "reason": "These functions independently reduce or position flex-line items; Lizard normalizes their short collection-loop prologues but sharing the unrelated bodies would require callback scaffolding and increase code size.",
      "regions": [
        {
          "file": "radiant/layout_flex.cpp",
          "start": "float find_max_baseline(",
          "end": "void reposition_baseline_items("
        },
        {
          "file": "radiant/layout_flex.cpp",
