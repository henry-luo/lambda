          "end": "bool is_main_axis_horizontal("
        },
        {
          "file": "radiant/layout_flex.cpp",
          "start": "static int create_flex_lines(FlexContainerLayout* flex_layout, View** items, int item_count) {",
          "end": "typedef struct FlexLengthScratch"
        },
        {
          "file": "radiant/layout_flex.cpp",
          "start": "static void resolve_flexible_lengths(FlexContainerLayout* flex_layout, FlexLineInfo* line) {",
          "end": "static float flex_line_outer_main_size("
        },
        {
          "file": "radiant/layout_flex.cpp",
          "start": "static float flex_line_outer_main_size(",
          "end": "static int flex_line_auto_margin_count("
        },
        {
