# Force LF line endings for all files (project developed on macOS/Linux)
* text=auto eol=lf

# Explicitly force LF for tree-sitter generated/vendored files
lambda/tree-sitter/**        text eol=lf
lambda/tree-sitter-lambda/** text eol=lf
lambda/tree-sitter-javascript/** text eol=lf
lambda/tree-sitter-latex/**  text eol=lf
lambda/tree-sitter-latex-math/** text eol=lf

# Binary files - don't touch
*.a    binary
*.o    binary
*.exe  binary
*.dll  binary
*.png  binary
*.jpg  binary
*.gif  binary
*.pdf  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.otf  binary
