// Lambda Development Container - VS Code Dev Container configuration
// See: https://containers.dev/implementors/json_reference/
{
    "name": "Lambda Dev",
    "dockerFile": "Dockerfile",
    "context": "..",
    "workspaceFolder": "/workspace",
    "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",

    // Run as the lambda user
    "remoteUser": "lambda",

    // VS Code extensions to install in the container
    "customizations": {
        "vscode": {
            "extensions": [
                // GitHub Copilot for AI-assisted coding
                "GitHub.copilot",
                "GitHub.copilot-chat",
                // C/C++ development
                "ms-vscode.cpptools",
                "ms-vscode.cmake-tools",
                // Git
                "eamodio.gitlens",
                // General development
                "ms-vscode.makefile-tools",
                "EditorConfig.EditorConfig"
            ],
            "settings": {
                "terminal.integrated.defaultProfile.linux": "bash",
                "editor.formatOnSave": false,
                "C_Cpp.default.cppStandard": "c++17",
                "C_Cpp.default.compilerPath": "/usr/bin/clang++",
                "C_Cpp.default.includePath": [
                    "${workspaceFolder}/**",
                    "/usr/local/include"
                ],
                "files.associations": {
                    "*.ls": "lambda",
                    "*.hpp": "cpp",
                    "*.h": "c"
                },
                "github.copilot.enable": {
                    "*": true,
                    "plaintext": true,
                    "markdown": true
                }
            }
        }
    },

    // Forward SSH and any dev server ports
    "forwardPorts": [22],

    // Run setup-linux-deps.sh on first container creation
    "postCreateCommand": "cd /workspace && ./setup-linux-deps.sh && make build",

    // Environment variables
    "remoteEnv": {
        "LAMBDA_DEV": "1"
    },

    // Container features
    "features": {
        "ghcr.io/devcontainers/features/git:1": {},
        "ghcr.io/devcontainers/features/github-cli:1": {}
    }
}
