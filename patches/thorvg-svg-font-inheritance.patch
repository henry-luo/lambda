diff --git a/src/loaders/svg/tvgSvgSceneBuilder.cpp b/src/loaders/svg/tvgSvgSceneBuilder.cpp
index cb86eff5..60bcc7a0 100644
--- a/src/loaders/svg/tvgSvgSceneBuilder.cpp
+++ b/src/loaders/svg/tvgSvgSceneBuilder.cpp
@@ -897,16 +897,37 @@ static Paint* _textBuildHelper(SvgLoaderData& loaderData, const SvgNode* node, c
 
     auto text = Text::gen();
 
+    // Resolve font-size and font-family: use text node's own values, or inherit from parent <g> elements.
+    float fontSize = textNode->fontSize;
+    const char* fontFamily = textNode->fontFamily;
+    if (!textNode->fontSizeSet || !textNode->fontFamilySet) {
+        // walk up the parent chain looking for inherited font attributes on <g> nodes
+        auto parent = node->parent;
+        while (parent) {
+            if (parent->type == SvgNodeType::G) {
+                if (!textNode->fontSizeSet && parent->node.g.fontSize > 0.0f) {
+                    fontSize = parent->node.g.fontSize;
+                }
+                if (!textNode->fontFamilySet && parent->node.g.fontFamily) {
+                    fontFamily = parent->node.g.fontFamily;
+                }
+            }
+            if ((textNode->fontSizeSet || fontSize != textNode->fontSize) &&
+                (textNode->fontFamilySet || fontFamily != textNode->fontFamily)) break;
+            parent = parent->parent;
+        }
+    }
+
     Matrix textTransform;
     if (node->transform) textTransform = *node->transform;
     else textTransform = tvg::identity();
 
-    translateR(&textTransform, {node->node.text.x, node->node.text.y - textNode->fontSize});
+    translateR(&textTransform, {node->node.text.x, node->node.text.y - fontSize});
     text->transform(textTransform);
 
     //TODO: handle def values of font and size as used in a system?
-    auto size = textNode->fontSize * 0.75f; //1 pt = 1/72; 1 in = 96 px; -> 72/96 = 0.75
-    if (text->font(textNode->fontFamily) != Result::Success) {
+    auto size = fontSize * 0.75f; //1 pt = 1/72; 1 in = 96 px; -> 72/96 = 0.75
+    if (text->font(fontFamily) != Result::Success) {
         text->font(nullptr);         //fallback to any available font
     }
     text->size(size);
