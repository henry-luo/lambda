flowchart TD
  INPUT["operand kinds + operation"] --> CLASSIFY["lambda_numeric_classify"]
  CLASSIFY --> SIZED["sized integer x sized integer"]
  SIZED -->|"+ - * div % bitwise shift"| LANE["selected sized lane<br/>Go-style wrap"]
  SIZED -->|"true /"| ENTRY
  CLASSIFY --> COMPACT["i8..u32 mixed with non-sized"]
  COMPACT -->|"enter by type"| INT["int domain"]
  CLASSIFY --> WIDE["i64/u64 mixed with non-sized"]
  WIDE -->|"enter exactly, independent of magnitude"| INTEGER["integer domain<br/>DECIMAL_BIGINT"]
  CLASSIFY --> SFLOAT["f16/f32 mixed with non-sized"]
  SFLOAT --> FLOAT["float domain"]
  INT --> JOIN["semantic join"]
  INTEGER --> JOIN
  FLOAT --> JOIN
  DECIMAL["decimal operand"] --> JOIN
  ENTRY["map sized operand to int or integer"] --> JOIN
  JOIN --> IRESULT["int + - *<br/>safe-band int, overflow to float"]
  JOIN --> FRESULT["float result<br/>int/int true / also enters here"]
  JOIN --> BIGRESULT["integer result<br/>exact arbitrary precision"]
  JOIN --> DRESULT["decimal result<br/>integer true / enters here"]
