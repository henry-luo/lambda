sequenceDiagram
    participant G as "GTest orchestrator (test_js_test262_gtest)"
    participant W as "posix_spawn worker (lambda.exe js-test-batch)"
    participant R as "LambdaJS runtime (persistent EvalContext)"
    G->>G: "partition_batch_indices: native vs js vs module vs slow"
    G->>G: "write temp/_t262_worker_N.manifest"
    G->>W: "harness:LEN + bytes (sta.js, assert.js, preamble includes)"
    W->>R: "transpile_js_to_mir_preamble_len, snapshot JsPreambleState"
    W->>R: "js_batch_reset_to(preamble_var_checkpoint)"
    loop "each test in sub-batch"
        G->>W: "source:NAME:PATH:LEN + bytes (or module-source)"
        W-->>G: "control byte 0x01 BATCH_START NAME"
        W->>R: "transpile_js_to_mir_with_preamble_len (arm sigsetjmp + alarm)"
        R-->>W: "stdout, exit result, phase timing"
        W-->>G: "control byte 0x01 BATCH_END status elapsed rss phases"
        W->>R: "js_batch_reset_to (or js_batch_reset if heavy/crash)"
    end
    Note over G,W: "watchdog thread SIGKILLs worker past hard timeout"
    G->>G: "evaluate_batch_result: PASS unless Test262Error or wrong exit"
