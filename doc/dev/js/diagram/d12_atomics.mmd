    J --> K{"finite timeout and <= 200ms?"}
    K -- "yes" --> L["advance virtual clock, resolve due waiters, return 'timed-out'"]
    K -- "no" --> M["return 'ok'"]
    N["Atomics.notify(ta, i, count)"] --> O["scan waiters for matching buffer+index"]
